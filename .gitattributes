# Normalización de fin de línea para todo el repositorio.
# Git decide automáticamente qué archivos son texto y normaliza a LF en el repo.
* text=auto

# Tipos de código fuente: siempre tratados como texto.
*.cs       text
*.xaml     text
*.csproj   text
*.sln      text
*.ps1      text
*.md       text
*.xml      text
*.json     text
*.resx     text

# Archivos binarios: nunca normalizar ni hacer diff de texto.
*.png      binary
*.ico      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.dll      binary
*.exe      binary
*.comb     binary
