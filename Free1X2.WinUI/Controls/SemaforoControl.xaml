<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Free1X2.WinUI.Controls.SemaforoControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid"
          Width="24" Height="24">

        <!-- Halo suave alrededor del punto (visible en estado activo) -->
        <Ellipse x:Name="Halo" Width="22" Height="22"
                 StrokeThickness="2" Opacity="0" />

        <!-- Punto principal del semáforo -->
        <Ellipse x:Name="Punto" Width="14" Height="14"
                 Opacity="0.55" />
    </Grid>
</UserControl>
