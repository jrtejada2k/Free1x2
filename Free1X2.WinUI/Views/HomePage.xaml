<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="1100" HorizontalAlignment="Left">

            <!-- Hero -->
            <StackPanel Spacing="6">
                <TextBlock Text="Free1X2" Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="Análisis estadístico de la Quiniela — ahora en WinUI 3"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
            </StackPanel>

            <!-- Tarjetas de acción -->
            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{ThemeResource AppSurfaceBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE762;" FontSize="24" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AppAccentBrush}" />
                        <TextBlock Text="Boleto" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Introduce tus 14 pronósticos y gestiona grupos."
                                   TextWrapping="Wrap" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{ThemeResource AppSurfaceBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE71C;" FontSize="24" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AppAccentBrush}" />
                        <TextBlock Text="Filtros y condiciones" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Aplica filtros matemáticos para reducir columnas."
                                   TextWrapping="Wrap" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="{ThemeResource AppSurfaceBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20">
                    <StackPanel Spacing="8">
                        <FontIcon Glyph="&#xE9D2;" FontSize="24" HorizontalAlignment="Left"
                                  Foreground="{ThemeResource AppAccentBrush}" />
                        <TextBlock Text="Estadísticas" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Analiza históricos y probabilidades."
                                   TextWrapping="Wrap" Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Showcase del sistema de diseño -->
            <Border Background="{ThemeResource AppSurfaceBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                    CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="Sistema de diseño Slate / Índigo" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Acción primaria" Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Secundaria" />
                        <ToggleSwitch Header="Estado" IsOn="True" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="64" Height="32" CornerRadius="6" Background="{ThemeResource AppSuccessBrush}" />
                        <Border Width="64" Height="32" CornerRadius="6" Background="{ThemeResource AppWarningBrush}" />
                        <Border Width="64" Height="32" CornerRadius="6" Background="{ThemeResource AppErrorBrush}" />
                        <Border Width="64" Height="32" CornerRadius="6" Background="{ThemeResource AppAccentBrush}" />
                    </StackPanel>
                    <InfoBar IsOpen="True" Severity="Success" IsClosable="False" Title="WinUI 3"
                             Message="Scaffold operativo: Mica, NavigationView, tema Light/Dark y paleta de marca." />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
