<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.ComponentesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Free1X2.WinUI.Controls">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="900" HorizontalAlignment="Left">

            <StackPanel Spacing="6">
                <TextBlock Text="Componentes" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Catálogo de las piezas reutilizables del sistema de diseño."
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

            <!-- ===== Semáforo ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Semáforo de filtros" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Indicador de 3 estados: vacío, activo y con error."
                               Style="{StaticResource SecondaryTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="32">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <controls:SemaforoControl Estado="Neutro" HorizontalAlignment="Center" />
                            <TextBlock Text="Neutro" Style="{StaticResource CaptionTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <controls:SemaforoControl Estado="Verde" HorizontalAlignment="Center" />
                            <TextBlock Text="Verde" Style="{StaticResource CaptionTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <controls:SemaforoControl Estado="Rojo" HorizontalAlignment="Center" />
                            <TextBlock Text="Rojo" Style="{StaticResource CaptionTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Botones de filtro ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Botones de filtro" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Cuatro estados semánticos: inactivo, neutro, activo y error."
                               Style="{StaticResource SecondaryTextBlockStyle}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Inactivo"
                                Style="{StaticResource FiltroButtonInactivoStyle}" />
                        <Button Grid.Column="1" Content="Neutro"
                                Style="{StaticResource FiltroButtonNeutroStyle}" />
                        <Button Grid.Column="2" Content="Activo"
                                Style="{StaticResource FiltroButtonActivoStyle}" />
                        <Button Grid.Column="3" Content="Error"
                                Style="{StaticResource FiltroButtonErrorStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Boleto ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Boleto" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="14 partidos con signos 1/X/2 y contador en vivo."
                               Style="{StaticResource SecondaryTextBlockStyle}" />
                    <controls:BoletoControl MaxWidth="560" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
