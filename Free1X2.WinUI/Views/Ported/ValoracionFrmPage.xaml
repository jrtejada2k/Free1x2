<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.ValoracionFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Free1X2.WinUI.Controls">

    <ScrollViewer>
        <StackPanel Padding="12,8" Spacing="8" MaxWidth="900" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Valoración" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Especifique los porcentajes para cada partido y acote el rango mínimo y máximo para los valores Global, 1, X y 2. Filtra las columnas cuya valoración cae dentro de los rangos indicados."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Porcentajes por partido (reemplaza el UserControl ControlPorcentajes) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock Text="Porcentajes" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Rejilla de valoraciones 1 / X / 2 por partido."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />
                    <controls:PorcentajesControl Height="260"
                                                 Filas="{x:Bind ViewModel.Porcentajes, Mode=OneWay}"
                                                 AutomationProperties.Name="Porcentajes 1 X 2 por partido" />

                    <!-- Botonera del UserControl ControlPorcentajes (ctrBarraBotones1): "Guardar"
                         abría GuardarValoracionFrm con la matriz de porcentajes (BGuardar). -->
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Button Content="Guardar valoración"
                                Command="{x:Bind ViewModel.GuardarValoracionCommand}"
                                AutomationProperties.Name="Guardar la valoración de porcentajes en un archivo" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Tipo de valoración + Mín-Máx informativos ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Tipo de valoración" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <ComboBox MinWidth="220"
                              Header="Modo"
                              ItemsSource="{x:Bind ViewModel.TiposValoracion}"
                              SelectedItem="{x:Bind ViewModel.TipoValoracionSeleccionado, Mode=TwoWay}"
                              AutomationProperties.Name="Tipo de valoración: por sumas o por productos" />

                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Mín-Máx Sumas"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 IsReadOnly="True"
                                 Text="{x:Bind ViewModel.MinMaxSumas, Mode=OneWay}"
                                 AutomationProperties.Name="Rango mínimo-máximo por sumas" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Mín-Máx Productos"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 IsReadOnly="True"
                                 Text="{x:Bind ViewModel.MinMaxProductos, Mode=OneWay}"
                                 AutomationProperties.Name="Rango mínimo-máximo por productos" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Rangos de filtrado (Global / 1 / X / 2) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Rangos de filtrado" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Use # como separador de rangos (ejemplo: 100-200#200-600)."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Global"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 PlaceholderText="100-200#200-600"
                                 Text="{x:Bind ViewModel.ValorGlobal, Mode=TwoWay}"
                                 AutomationProperties.Name="Rango de valoración global" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 PlaceholderText="0-100"
                                 Text="{x:Bind ViewModel.ValorUnos, Mode=TwoWay}"
                                 AutomationProperties.Name="Rango de valoración del signo 1" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="X"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 PlaceholderText="0-100"
                                 Text="{x:Bind ViewModel.ValorEquis, Mode=TwoWay}"
                                 AutomationProperties.Name="Rango de valoración del signo X" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 PlaceholderText="0-100"
                                 Text="{x:Bind ViewModel.ValorDoses, Mode=TwoWay}"
                                 AutomationProperties.Name="Rango de valoración del signo 2" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Calcular valoración de una columna ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Calcular valoración" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Columna"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 CharacterCasing="Upper"
                                 PlaceholderText="Columna de N signos (1 / X / 2)"
                                 Text="{x:Bind ViewModel.Columna, Mode=TwoWay}"
                                 AutomationProperties.Name="Columna de signos a valorar" />
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Valor"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 IsReadOnly="True"
                                 Text="{x:Bind ViewModel.Resultado, Mode=OneWay}"
                                 AutomationProperties.Name="Resultado de la valoración" />
                        <Button Grid.Column="2"
                                Content="Calcula"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.CalcularCommand}"
                                AutomationProperties.Name="Calcular la valoración de la columna" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Utilidades ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Utilidades" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Button Content="Buscar límite"
                                Command="{x:Bind ViewModel.BuscarLimiteCommand}"
                                AutomationProperties.Name="Abrir el buscador de límites" />
                        <Button Content="Columnas base"
                                Command="{x:Bind ViewModel.GenerarColumnasBaseCommand}"
                                AutomationProperties.Name="Generar las columnas base" />
                    </StackPanel>

                    <TextBox IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="80"
                             Text="{x:Bind ViewModel.ColumnasBase, Mode=OneWay}"
                             AutomationProperties.Name="Columnas base generadas (mayor, medio, menor)" />
                </StackPanel>
            </Border>

            <!-- ===== Barra de condiciones (control legacy MenuCondiciones) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Condición" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Button Content="Aceptar"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.AceptarCommand}"
                                AutomationProperties.Name="Aceptar y activar el filtro" />
                        <Button Content="Estadísticas"
                                Command="{x:Bind ViewModel.EstadisticasCommand}"
                                AutomationProperties.Name="Ver estadísticas del filtro" />
                        <Button Content="Guardar"
                                Command="{x:Bind ViewModel.GuardarCommand}"
                                AutomationProperties.Name="Guardar la condición en un archivo" />
                        <Button Content="Abrir"
                                Command="{x:Bind ViewModel.AbrirCommand}"
                                AutomationProperties.Name="Abrir una condición desde un archivo" />
                        <Button Content="Copiar"
                                Command="{x:Bind ViewModel.CopiarCommand}"
                                AutomationProperties.Name="Copiar la condición" />
                        <Button Content="Pegar"
                                Command="{x:Bind ViewModel.PegarCommand}"
                                AutomationProperties.Name="Pegar la condición copiada" />
                        <Button Content="Borrar"
                                Command="{x:Bind ViewModel.BorrarCommand}"
                                AutomationProperties.Name="Borrar los datos del filtro" />
                        <Button Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar y cerrar" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
