<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AgregarEquipoFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="12,8" Spacing="8" MaxWidth="640" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Añadir Equipo"
                           Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Da de alta un equipo nuevo indicando su nombre y la categoría a la que pertenece. Si el equipo ya existe en esa categoría no se duplica."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Datos del equipo ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Datos del equipo" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <!-- Nombre (txtEquipo + label1 "Nombre") -->
                    <TextBox Header="Nombre"
                             PlaceholderText="Nombre del equipo"
                             Text="{x:Bind ViewModel.NombreEquipo, Mode=TwoWay}"
                             MaxWidth="320" HorizontalAlignment="Left"
                             AutomationProperties.Name="Nombre del equipo" />

                    <!-- Categoría (rdbPrimera / rdbSegunda / rdbSegundaB / rdbInt) -->
                    <ComboBox Header="Categoría"
                              MinWidth="160" HorizontalAlignment="Left"
                              ItemsSource="{x:Bind ViewModel.Categorias}"
                              SelectedItem="{x:Bind ViewModel.Categoria, Mode=TwoWay}"
                              AutomationProperties.Name="Categoría del equipo" />
                </StackPanel>
            </Border>

            <!-- ===== Acción + estado ===== -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Content="Añadir"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.AnadirCommand}"
                        AutomationProperties.Name="Añadir el equipo a su categoría" />
                <TextBlock Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
