<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AcercaDeFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{ThemeResource AppBackgroundBrush}">
        <Grid Padding="12,8" RowSpacing="6" MaxWidth="640" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado: título real del form + lema -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Acerca de" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="El primer programa de quinielas libre y gratuito"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
            </StackPanel>

            <!-- Tarjeta de identidad: logo + nombre + versión -->
            <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo de la aplicación -->
                    <Border Grid.Column="0"
                            Width="96" Height="96"
                            Background="{ThemeResource AppSurfaceAltBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource AppCardCornerRadius}">
                        <Image x:Name="LogoImage"
                               Stretch="Uniform"
                               Margin="8"
                               AutomationProperties.Name="Logo de Free1X2" />
                    </Border>

                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Free1X2"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   Foreground="{ThemeResource AppAccentBrush}" />
                        <TextBlock x:Name="VersionTextBlock"
                                   Text="Versión …"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Foreground="{ThemeResource AppTextBrush}" />
                        <HyperlinkButton x:Name="SitioWebLink"
                                         Content="www.clubprogol.com"
                                         Padding="0"
                                         Click="SitioWebLink_Click"
                                         AutomationProperties.Name="Abrir el sitio web www.clubprogol.com" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tarjeta de enlaces -->
            <Border Grid.Row="2" Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Enlaces"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource AppTextBrush}"
                               Margin="0,0,0,4" />

                    <HyperlinkButton Content="Información de licencia"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="LicenciaLink_Click"
                                     AutomationProperties.Name="Ver información de licencia" />

                    <HyperlinkButton Content="Sobre el software libre"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="GplLink_Click"
                                     AutomationProperties.Name="Ver la licencia GPL del software libre" />

                    <HyperlinkButton Content="Descarga"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="DescargaLink_Click"
                                     AutomationProperties.Name="Ir a la página de descargas" />

                    <HyperlinkButton Content="Manual"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="ManualLink_Click"
                                     AutomationProperties.Name="Abrir el manual de usuario" />

                    <HyperlinkButton Content="Foro sobre el programa"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="ForoLink_Click"
                                     AutomationProperties.Name="Abrir el foro sobre el programa" />

                    <HyperlinkButton Content="Créditos"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="CreditosLink_Click"
                                     AutomationProperties.Name="Ver los créditos del programa" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
