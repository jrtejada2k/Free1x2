<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.MultiplicadorFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="10,7" MaxWidth="720" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
                <TextBlock
                    Text="Multiplicador"
                    Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock
                    Text="Multiplica (producto cartesiano) dos combinaciones de 14 signos en columnas de 28 cifras, reordenadas según una plantilla."
                    Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

            <!-- Tarjeta: Entrada Comb-1 (columnas numeradas de 1 a 14) -->
            <Border Grid.Row="1" Style="{StaticResource AppCardStyle}" Margin="0,0,0,8">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Entrada Comb-1"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />
                    <TextBlock
                        Text="Columnas numeradas de 1 a 14."
                        Style="{StaticResource SecondaryTextBlockStyle}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Content="Seleccionar archivo…"
                            IsEnabled="{x:Bind ViewModel.PuedeProcesar, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SeleccionarEntrada1Command}"
                            AutomationProperties.Name="Seleccionar archivo de la Entrada Comb-1" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.NombreEntrada1, Mode=OneWay}"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock
                                Text="Columnas:"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ColumnasEntrada1Texto, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Foreground="{ThemeResource AppTextBrush}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Tarjeta: Entrada Comb-2 (columnas numeradas de 15 a 28) -->
            <Border Grid.Row="2" Style="{StaticResource AppCardStyle}" Margin="0,0,0,8">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Entrada Comb-2"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />
                    <TextBlock
                        Text="Columnas numeradas de 15 a 28."
                        Style="{StaticResource SecondaryTextBlockStyle}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            Content="Seleccionar archivo…"
                            IsEnabled="{x:Bind ViewModel.PuedeProcesar, Mode=OneWay}"
                            Command="{x:Bind ViewModel.SeleccionarEntrada2Command}"
                            AutomationProperties.Name="Seleccionar archivo de la Entrada Comb-2" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind ViewModel.NombreEntrada2, Mode=OneWay}"
                            VerticalAlignment="Center"
                            TextTrimming="CharacterEllipsis"
                            Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <TextBlock
                                Text="Columnas:"
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ColumnasEntrada2Texto, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Foreground="{ThemeResource AppTextBrush}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Tarjeta: Plantilla de estructura de las columnas resultantes -->
            <Border Grid.Row="3" Style="{StaticResource AppCardStyle}" Margin="0,0,0,8">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Plantilla de estructura"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />
                    <TextBlock
                        Text="Plantilla de estructura de las columnas resultantes (cifras de ejemplo). El cambio de orden de estas cifras (1 a 28) permite transponer columnas al mismo tiempo."
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        TextWrapping="Wrap" />

                    <!-- 14 índices de la plantilla (1..28). NumberBox.Value es double. -->
                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <NumberBox Grid.Row="0" Grid.Column="0" Header="1" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice01, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 1" />
                        <NumberBox Grid.Row="0" Grid.Column="1" Header="2" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice02, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 2" />
                        <NumberBox Grid.Row="0" Grid.Column="2" Header="3" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice03, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 3" />
                        <NumberBox Grid.Row="0" Grid.Column="3" Header="4" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice04, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 4" />
                        <NumberBox Grid.Row="0" Grid.Column="4" Header="5" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice05, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 5" />
                        <NumberBox Grid.Row="0" Grid.Column="5" Header="6" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice06, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 6" />
                        <NumberBox Grid.Row="0" Grid.Column="6" Header="7" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice07, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 7" />

                        <NumberBox Grid.Row="1" Grid.Column="0" Header="8" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice08, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 8" />
                        <NumberBox Grid.Row="1" Grid.Column="1" Header="9" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice09, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 9" />
                        <NumberBox Grid.Row="1" Grid.Column="2" Header="10" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice10, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 10" />
                        <NumberBox Grid.Row="1" Grid.Column="3" Header="11" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice11, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 11" />
                        <NumberBox Grid.Row="1" Grid.Column="4" Header="12" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice12, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 12" />
                        <NumberBox Grid.Row="1" Grid.Column="5" Header="13" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice13, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 13" />
                        <NumberBox Grid.Row="1" Grid.Column="6" Header="14" Minimum="1" Maximum="28"
                            SpinButtonPlacementMode="Compact"
                            Value="{x:Bind ViewModel.Indice14, Mode=TwoWay}"
                            AutomationProperties.Name="Índice de plantilla 14" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Tarjeta: Resultado -->
            <Border Grid.Row="4" Style="{StaticResource AppCardStyle}" Margin="0,0,0,8">
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Resultado"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            Text="Columnas resultantes:"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ColumnasResultadoTexto, Mode=OneWay}"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                    </StackPanel>
                    <TextBlock
                        Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}"
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource AppErrorBrush}" />
                </StackPanel>
            </Border>

            <!-- Acciones -->
            <StackPanel
                Grid.Row="5"
                Orientation="Horizontal"
                Spacing="5"
                HorizontalAlignment="Right">
                <Button
                    Content="Grabar resultado"
                    IsEnabled="{x:Bind ViewModel.PuedeGrabar, Mode=OneWay}"
                    Command="{x:Bind ViewModel.GrabarCommand}"
                    AutomationProperties.Name="Grabar el resultado a archivo" />
                <Button
                    Content="Multiplicar"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.PuedeProcesar, Mode=OneWay}"
                    Command="{x:Bind ViewModel.MultiplicarCommand}"
                    AutomationProperties.Name="Multiplicar las dos entradas" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
