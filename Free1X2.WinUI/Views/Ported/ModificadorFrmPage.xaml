<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.ModificadorFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="Modificador de columnas"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Carga un fichero de columnas, ajusta el porcentaje 1/X/2 de cada partido y redistribuye los signos según el modo elegido."
                Style="{StaticResource SecondaryTextBlockStyle}"
                TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Columna izquierda: partidos y porcentajes -->
            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Partidos"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <!-- Cabecera de columnas -->
                    <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,12,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nº" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="% 1" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="% X" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="3" Text="% 2" Style="{StaticResource CaptionTextBlockStyle}" />
                    </Grid>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Partidos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:ModificadorPartido">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Activa el partido (legacy chckActive). El número va como contenido. -->
                                        <CheckBox
                                            Grid.Column="0"
                                            Content="{x:Bind NumeroTexto}"
                                            IsChecked="{x:Bind Activo, Mode=TwoWay}"
                                            MinWidth="0"
                                            AutomationProperties.Name="Activar partido" />

                                        <!-- Cada NumberBox se habilita por sí mismo según 'Activo' (anti-crash regla 1). -->
                                        <NumberBox
                                            Grid.Column="1"
                                            Value="{x:Bind Valor1, Mode=TwoWay}"
                                            IsEnabled="{x:Bind Activo, Mode=OneWay}"
                                            Minimum="0"
                                            Maximum="100"
                                            SpinButtonPlacementMode="Hidden"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.Name="Porcentaje del signo 1" />
                                        <NumberBox
                                            Grid.Column="2"
                                            Value="{x:Bind ValorX, Mode=TwoWay}"
                                            IsEnabled="{x:Bind Activo, Mode=OneWay}"
                                            Minimum="0"
                                            Maximum="100"
                                            SpinButtonPlacementMode="Hidden"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.Name="Porcentaje del signo X" />
                                        <NumberBox
                                            Grid.Column="3"
                                            Value="{x:Bind Valor2, Mode=TwoWay}"
                                            IsEnabled="{x:Bind Activo, Mode=OneWay}"
                                            Minimum="0"
                                            Maximum="100"
                                            SpinButtonPlacementMode="Hidden"
                                            HorizontalAlignment="Stretch"
                                            AutomationProperties.Name="Porcentaje del signo 2" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Columna derecha: fichero, distribución y acciones -->
            <StackPanel Grid.Column="1" Spacing="16">

                <!-- Fichero de entrada -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Fichero de entrada"
                            Style="{StaticResource SectionHeaderTextBlockStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.FicheroNombre, Mode=OneWay}"
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <Button
                            Content="Abrir fichero…"
                            Command="{x:Bind ViewModel.AbrirCommand}"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Abrir fichero de columnas" />
                    </StackPanel>
                </Border>

                <!-- Distribución de los signos -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Distribución de los signos"
                            Style="{StaticResource SectionHeaderTextBlockStyle}" />
                        <ComboBox
                            Header="Modo"
                            ItemsSource="{x:Bind ViewModel.DistribucionOpciones}"
                            SelectedItem="{x:Bind ViewModel.DistribucionSeleccionada, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />
                        <ToggleSwitch
                            Header="Ordenar signos"
                            OnContent="Sí"
                            OffContent="No"
                            IsOn="{x:Bind ViewModel.OrdenarSignos, Mode=TwoWay}"
                            IsEnabled="{x:Bind ViewModel.OrdenarHabilitado, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <!-- Acciones -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="8">
                        <Button
                            Content="Ok"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.AceptarCommand}"
                            IsEnabled="{x:Bind ViewModel.FicheroCargado, Mode=OneWay}"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Content="Grabar"
                            Command="{x:Bind ViewModel.GrabarCommand}"
                            IsEnabled="{x:Bind ViewModel.FicheroCargado, Mode=OneWay}"
                            HorizontalAlignment="Stretch" />
                        <Button
                            Content="Cancelar"
                            Command="{x:Bind ViewModel.CancelarCommand}"
                            HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</Page>
