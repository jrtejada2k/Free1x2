<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.GEPTFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="Columna estadística de ABDON (GEPT)"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Para cada partido indica las dos últimas veces que se repitió el enfrentamiento (G = Ganó, E = Empató, P = Perdió). El sistema deriva el pronóstico de signos."
                Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <!-- Tarjeta de la columna -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            MaxWidth="520">
            <StackPanel Spacing="16">

                <!-- Cabecera de columnas -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="Nº"
                        Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock
                        Grid.Column="1"
                        Text="Última vez"
                        Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock
                        Grid.Column="2"
                        Text="Penúltima vez"
                        Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock
                        Grid.Column="3"
                        Text="Pronóstico"
                        Style="{StaticResource CardTitleTextBlockStyle}" />
                </Grid>

                <!-- Filas de partidos -->
                <ItemsControl ItemsSource="{x:Bind ViewModel.Partidos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:GEPTFila">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Text="{x:Bind NumeroTexto}"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <ComboBox
                                    Grid.Column="1"
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{x:Bind OpcionesSigno}"
                                    SelectedItem="{x:Bind Primera, Mode=TwoWay}"
                                    AutomationProperties.Name="Última ocasión (G/E/P)" />
                                <ComboBox
                                    Grid.Column="2"
                                    HorizontalAlignment="Stretch"
                                    ItemsSource="{x:Bind OpcionesSigno}"
                                    SelectedItem="{x:Bind Segunda, Mode=TwoWay}"
                                    AutomationProperties.Name="Penúltima ocasión (G/E/P)" />
                                <Border
                                    Grid.Column="3"
                                    Background="{ThemeResource AppSurfaceAltBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    MinHeight="32"
                                    Padding="8,0">
                                    <TextBlock
                                        Text="{x:Bind Resultado, Mode=OneWay}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Acciones -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
                    <Button
                        Content="Calcular"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.CalcularCommand}"
                        AutomationProperties.Name="Calcular pronóstico de la columna GEPT" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
