<Page
    x:Class="Free1X2.WinUI.Views.Ported.ListaEquiposFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado: título real del form legacy ("Lista de Equipos") -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                Style="{StaticResource PageTitleTextBlockStyle}"
                Text="Lista de Equipos" />
            <TextBlock
                Style="{StaticResource SecondaryTextBlockStyle}"
                Text="Selecciona un equipo de la categoría para asignarlo." />
        </StackPanel>

        <!-- Búsqueda / filtro -->
        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <StackPanel Spacing="12">
                <TextBlock
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Text="Buscar" />
                <TextBox
                    PlaceholderText="Filtrar equipos..."
                    Text="{x:Bind ViewModel.TextoBusqueda, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- Lista de equipos (legacy: listBox1, ordenado) -->
        <Border Grid.Row="2" Style="{StaticResource AppCardStyle}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Text="Equipos" />

                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Equipos, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.EquipoSeleccionado, Mode=TwoWay}"
                    SelectionMode="Single" />

                <TextBlock
                    Grid.Row="2"
                    Style="{StaticResource SecondaryTextBlockStyle}"
                    Text="{x:Bind ViewModel.MensajeEstado, Mode=OneWay}" />
            </Grid>
        </Border>

        <!-- Acciones -->
        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="12">
            <Button
                Command="{x:Bind ViewModel.CargarCommand}"
                Content="Recargar" />
            <Button
                Command="{x:Bind ViewModel.SeleccionarCommand}"
                Content="Seleccionar"
                IsEnabled="{x:Bind ViewModel.HaySeleccion, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Page>
