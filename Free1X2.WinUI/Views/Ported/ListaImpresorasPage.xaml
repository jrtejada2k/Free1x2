<Page
    x:Class="Free1X2.WinUI.Views.Ported.ListaImpresorasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="10,7" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                Style="{StaticResource PageTitleTextBlockStyle}"
                Text="Lista Impresoras Conocidas" />
            <TextBlock
                Style="{StaticResource SecondaryTextBlockStyle}"
                Text="Doble clic sobre una impresora de la lista para aplicar su configuración." />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Text="Impresoras" />

                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Impresoras, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.ImpresoraSeleccionada, Mode=TwoWay}"
                    DoubleTapped="OnImpresoraDoubleTapped"
                    SelectionMode="Single" />

                <Border
                    Grid.Row="2"
                    Background="{StaticResource AppSurfaceAltBrush}"
                    BorderBrush="{StaticResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,8">
                    <TextBlock
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}"
                        TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
