<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.CombinarFiltrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <!-- Layout 3 columnas replicando el WinForms legacy CombinarFiltros (632x430):
         Col 1 = grid Filtros (full height), Col 2 = pila de botones + NOTA,
         Col 3 = groupBox2 "Salida". -->
    <Grid Padding="12,8" RowSpacing="6" ColumnSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Spacing="4">
            <TextBlock Text="Combinación de Filtros"
                       Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Text="Combina varios archivos de columnas y cuenta en cuántos filtros aparece cada una."
                       Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <!-- ============ Col 1: lista de filtros (dataGrid1 legacy), full height ============ -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource AppCardStyle}">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Filtros"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <!-- DataGridView legacy -> ListView (N / Filtro / Activo / Cols.) -->
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Filtros, Mode=OneWay}"
                          SelectionMode="None"
                          Background="{ThemeResource AppSurfaceAltBrush}"
                          BorderBrush="{ThemeResource AppBorderBrush}"
                          BorderThickness="1">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="N"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                <TextBlock Grid.Column="1" Text="Filtro"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                <TextBlock Grid.Column="2" Text="Activo"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                <TextBlock Grid.Column="3" Text="Cols."
                                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:FiltroFilaViewModel">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="70" />
                                    <ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind NumeroTexto, Mode=OneWay}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Nombre, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" />
                                <CheckBox Grid.Column="2"
                                          IsChecked="{x:Bind Activo, Mode=TwoWay}"
                                          VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3"
                                           Text="{x:Bind ColumnasTexto, Mode=OneWay}"
                                           HorizontalTextAlignment="Right"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- ============ Col 2: pila de botones (orden legacy) + NOTA ============ -->
        <StackPanel Grid.Row="1" Grid.Column="1" Width="150" Spacing="6">
            <!-- btnCargarFiltro -->
            <Button Content="Cargar Filtro"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CargarFiltroCommand}" />
            <!-- ckMD: Activa / Desactiva (toggle/checkbox) -->
            <ToggleSwitch Header="Activa / Desactiva"
                          IsOn="{x:Bind ViewModel.ActivarTodas, Mode=TwoWay}"
                          Toggled="ActivarTodas_Toggled" />
            <!-- bSalvaLista -->
            <Button Content="Salvar Lista"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.SalvarListaCommand}" />
            <!-- bCargaLista -->
            <Button Content="Cargar Lista"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CargarListaCommand}" />

            <!-- gap -->
            <Border Height="8" />

            <!-- bIniciar (acento) -->
            <Button Content="Iniciar Proceso"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.IniciarCommand}" />
            <!-- bCancelar -->
            <Button Content="Cancelar"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.CancelarCommand}" />

            <!-- gap -->
            <Border Height="8" />

            <!-- btnReiniciaTodo -->
            <Button Content="Reiniciar Todo"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ReiniciarTodoCommand}" />

            <!-- label3 NOTA legacy -->
            <TextBlock Text="Cualquier variación en el cuadro &quot;Filtros&quot; requiere repetir el proceso antes de sumar o grabar columnas."
                       Style="{StaticResource SecondaryTextBlockStyle}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- ============ Col 3: groupBox2 "Salida" legacy ============ -->
        <Border Grid.Row="1" Grid.Column="2"
                Width="170"
                VerticalAlignment="Top"
                Style="{StaticResource AppCardStyle}">
            <StackPanel Spacing="6">
                <TextBlock Text="Salida"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <!-- label "Filtros Acertados" -->
                <TextBlock Text="Filtros acertados"
                           Style="{StaticResource CardTitleTextBlockStyle}" />

                <!-- tbmin / tbmax: rango [Mínimo, Máximo] -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <NumberBox Grid.Column="0"
                               Header="Mínimo"
                               Minimum="1"
                               SpinButtonPlacementMode="Compact"
                               Value="{x:Bind ViewModel.Minimo, Mode=TwoWay}" />
                    <NumberBox Grid.Column="1"
                               Header="Máximo"
                               Minimum="1"
                               SpinButtonPlacementMode="Compact"
                               Value="{x:Bind ViewModel.Maximo, Mode=TwoWay}" />
                </Grid>

                <!-- bSumaCols -->
                <Button Content="Sumar cols."
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.SumarColumnasCommand}" />

                <!-- lCols: total de columnas -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Total columnas"
                               Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.TotalColumnasTexto, Mode=OneWay}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                </StackPanel>

                <!-- btnGrabarFiltro -->
                <Button Content="Grabar cols."
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.GrabarColumnasCommand}" />

                <!-- lfilout: archivo de salida -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Archivo de salida"
                               Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.ArchivoSalida, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
