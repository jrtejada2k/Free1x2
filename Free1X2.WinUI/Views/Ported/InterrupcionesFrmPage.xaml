<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.InterrupcionesFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="820" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Interrupciones" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Una interrupción es cada cambio de signo que se produce a lo largo de la columna."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Interrupciones ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Interrupciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Número de interrupciones admitidas (0–14) por tipo. Separa varios valores con comas, p. ej. 0,1,2."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <!-- Global -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Global"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.IntGlobal, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones globales admitidas" />
                    </Grid>

                    <!-- Var -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Var"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.IntVar, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones para cualquier signo (Var)" />
                    </Grid>

                    <!-- 1 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.Int1, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones para el signo 1" />
                    </Grid>

                    <!-- X -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.IntX, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones para el signo X" />
                    </Grid>

                    <!-- 2 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.Int2, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones para el signo 2" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Interrupciones seguidas ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Seguidas" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Número de interrupciones seguidas admitidas (0–14) por tipo. Separa varios valores con comas, p. ej. 0,1,2."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <!-- Global -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Global"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.SegGlobal, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones seguidas globales admitidas" />
                    </Grid>

                    <!-- Var -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Var"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.SegVar, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones seguidas para cualquier signo (Var)" />
                    </Grid>

                    <!-- 1 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.Seg1, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones seguidas para el signo 1" />
                    </Grid>

                    <!-- X -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.SegX, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones seguidas para el signo X" />
                    </Grid>

                    <!-- 2 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0,1,2"
                                 Text="{x:Bind ViewModel.Seg2, Mode=TwoWay}"
                                 AutomationProperties.Name="Interrupciones seguidas para el signo 2" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Acciones (menuCondiciones del form legacy) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Acciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Aceptar"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.AceptarCommand}"
                                AutomationProperties.Name="Aceptar y aplicar el filtro de interrupciones" />
                        <Button Content="Estadísticas"
                                Command="{x:Bind ViewModel.EstadisticasCommand}"
                                AutomationProperties.Name="Ver estadísticas del filtro" />
                        <Button Content="Guardar"
                                Command="{x:Bind ViewModel.GuardarCommand}"
                                AutomationProperties.Name="Guardar la condición en un archivo" />
                        <Button Content="Abrir"
                                Command="{x:Bind ViewModel.AbrirCommand}"
                                AutomationProperties.Name="Abrir una condición desde un archivo" />
                        <Button Content="Copiar"
                                Command="{x:Bind ViewModel.CopiarCommand}"
                                AutomationProperties.Name="Copiar la condición a un archivo temporal" />
                        <Button Content="Pegar"
                                Command="{x:Bind ViewModel.PegarCommand}"
                                AutomationProperties.Name="Pegar la condición desde el archivo temporal" />
                        <Button Content="Borrar"
                                Command="{x:Bind ViewModel.BorrarCommand}"
                                AutomationProperties.Name="Borrar todos los valores" />
                        <Button Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar y cerrar" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
