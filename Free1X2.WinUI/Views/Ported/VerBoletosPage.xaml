<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.VerBoletosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado (Text del form legacy: "Ver Boletos") -->
        <StackPanel Grid.Row="0" Padding="32,32,32,8" Spacing="4">
            <TextBlock Text="Ver Boletos" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Text="Abre un fichero de columnas y muestra el boleto, eligiendo el criterio y el sentido de ordenación."
                       Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Contenido desplazable -->
        <ScrollViewer Grid.Row="1" Padding="32,8,32,8" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="820" HorizontalAlignment="Left">

                <!-- Tarjeta: fichero de columnas (TextBox 'fichero' + Button 'abrir') -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Fichero de columnas" Style="{StaticResource CardTitleTextBlockStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Content="Seleccionar archivo..."
                                    Command="{x:Bind ViewModel.SeleccionarFicheroCommand}"
                                    AutomationProperties.Name="Seleccionar fichero de columnas" />
                            <TextBlock Text="{x:Bind ViewModel.Fichero, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextBlockStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Tarjeta: criterio de ordenación (groupBox1 "Ordenar por ...") -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Ordenar por ..." Style="{StaticResource CardTitleTextBlockStyle}" />

                        <RadioButton Content="No ordenar" GroupName="Ordenar"
                                     IsChecked="{x:Bind ViewModel.OrdenarNoOrdenar, Mode=TwoWay}"
                                     AutomationProperties.Name="Ordenar: no ordenar" />
                        <RadioButton Content="Variantes" GroupName="Ordenar"
                                     IsChecked="{x:Bind ViewModel.OrdenarVariantes, Mode=TwoWay}"
                                     AutomationProperties.Name="Ordenar: variantes" />
                        <RadioButton Content="X" GroupName="Ordenar"
                                     IsChecked="{x:Bind ViewModel.OrdenarEquis, Mode=TwoWay}"
                                     AutomationProperties.Name="Ordenar: equis" />
                        <RadioButton Content="2" GroupName="Ordenar"
                                     IsChecked="{x:Bind ViewModel.OrdenarDoses, Mode=TwoWay}"
                                     AutomationProperties.Name="Ordenar: doses" />
                        <RadioButton Content="Interrupciones" GroupName="Ordenar"
                                     IsChecked="{x:Bind ViewModel.OrdenarInterrupciones, Mode=TwoWay}"
                                     AutomationProperties.Name="Ordenar: interrupciones" />
                        <!-- o5 estaba deshabilitado en el form legacy (Enabled = false) -->
                        <RadioButton Content="Signos seguidos" GroupName="Ordenar"
                                     IsEnabled="False"
                                     IsChecked="{x:Bind ViewModel.OrdenarSignosSeguidos, Mode=TwoWay}"
                                     AutomationProperties.Name="Ordenar: signos seguidos (no disponible)" />
                    </StackPanel>
                </Border>

                <!-- Tarjeta: sentido de ordenación (groupBox2 "Tipo de ordenamiento") -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Tipo de ordenamiento" Style="{StaticResource CardTitleTextBlockStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <RadioButton Content="ascendente" GroupName="Sentido"
                                         IsChecked="{x:Bind ViewModel.SentidoAscendente, Mode=TwoWay}"
                                         AutomationProperties.Name="Orden ascendente" />
                            <RadioButton Content="descendente" GroupName="Sentido"
                                         IsChecked="{x:Bind ViewModel.SentidoDescendente, Mode=TwoWay}"
                                         AutomationProperties.Name="Orden descendente" />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Barra de acciones (btnOk / btnCancel del form legacy) -->
        <Border Grid.Row="2" Padding="32,16"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                           Style="{StaticResource SecondaryTextBlockStyle}" />

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button Content="Cancelar"
                            Click="BtnCancelar_Click"
                            Command="{x:Bind ViewModel.CancelarCommand}"
                            AutomationProperties.Name="Cancelar y cerrar" />
                    <!-- btnOk: deshabilitado hasta elegir fichero (btnOk.Enabled = true en abrir_Click) -->
                    <Button Content="Ok" Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.OkHabilitado, Mode=OneWay}"
                            Command="{x:Bind ViewModel.MostrarBoletoCommand}"
                            AutomationProperties.Name="Mostrar boleto" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
