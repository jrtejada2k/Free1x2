<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.VSignosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="10,7" RowSpacing="8" MaxWidth="900" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock
                    Text="Análisis de signos"
                    Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock
                    Text="Procesa un fichero de columnas y contabiliza, partido a partido, cuántas veces aparece cada signo (1, X, 2)."
                    Style="{StaticResource SecondaryTextBlockStyle}"
                    Foreground="{ThemeResource AppTextSecondaryBrush}" />
            </StackPanel>

            <!-- Fichero de entrada -->
            <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Fichero a procesar"
                        Style="{StaticResource SectionHeaderTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            PlaceholderText="Ruta del fichero de columnas"
                            Text="{x:Bind ViewModel.FicheroEntrada, Mode=TwoWay}"
                            AutomationProperties.Name="Ruta del fichero de columnas" />
                        <Button
                            Grid.Column="1"
                            Content="Examinar…"
                            Command="{x:Bind ViewModel.AbrirFicheroCommand}"
                            AutomationProperties.Name="Examinar y seleccionar fichero de columnas" />
                    </Grid>
                    <TextBlock
                        Text="{x:Bind ViewModel.NombreFicheroEntrada, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Parámetros de análisis -->
            <Border Grid.Row="2" Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock
                        Text="Ver"
                        Style="{StaticResource SectionHeaderTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />

                    <!-- Modo de presentación (legacy: rbcen0 / rbcen2 / rbcol) -->
                    <ComboBox
                        Header="Formato de presentación"
                        ItemsSource="{x:Bind ViewModel.ModosPresentacion}"
                        SelectedItem="{x:Bind ViewModel.ModoPresentacion, Mode=TwoWay}"
                        MinWidth="220"
                        AutomationProperties.Name="Formato de presentación de los porcentajes" />

                    <!-- Pleno al 15 (legacy: chkPleno) -->
                    <ToggleSwitch
                        Header="Considerar último partido como Pleno"
                        OffContent="No"
                        OnContent="Sí"
                        IsOn="{x:Bind ViewModel.ConsiderarPleno, Mode=TwoWay}"
                        AutomationProperties.Name="Considerar el último partido como Pleno al 15" />

                    <!-- Aspiración (legacy: lbasp + bMas / bMenos) -->
                    <StackPanel Spacing="6">
                        <TextBlock
                            Text="Aspirando a… (nº mínimo de aciertos para el escrutinio parcial)"
                            Style="{StaticResource CardTitleTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                Value="{x:Bind ViewModel.Aspiracion, Mode=TwoWay}"
                                Minimum="0"
                                SpinButtonPlacementMode="Inline"
                                SmallChange="1"
                                Width="160"
                                AutomationProperties.Name="Nivel de aspiración" />
                            <Button
                                Content="−"
                                Command="{x:Bind ViewModel.BajarAspiracionCommand}"
                                AutomationProperties.Name="Bajar el nivel de aspiración" />
                            <Button
                                Content="+"
                                Command="{x:Bind ViewModel.SubirAspiracionCommand}"
                                AutomationProperties.Name="Subir el nivel de aspiración" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Columna ganadora editable (legacy: txts[] -> part[]) -->
                    <StackPanel Spacing="6">
                        <TextBlock
                            Text="Columna ganadora (escrutinio parcial)"
                            Style="{StaticResource CardTitleTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock
                            Text="Introduzca el signo conocido de cada partido (1 / X / 2). Use - como comodín para los partidos aún sin resultado."
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            Foreground="{ThemeResource AppTextSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnaGanadora, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VariableSizedWrapGrid
                                        Orientation="Horizontal"
                                        ItemWidth="80"
                                        ItemHeight="40" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:CasillaColumnaGanadora">
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Partido}"
                                                   Width="24"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                        <TextBox Text="{x:Bind Signo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="44"
                                                 MaxLength="1"
                                                 CharacterCasing="Upper"
                                                 TextAlignment="Center"
                                                 AutomationProperties.Name="Signo de la columna ganadora del partido" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock
                        Text="Nota: la columna ganadora y la casilla de aspiración sirven para el escrutinio parcial de las tardes de sábado y domingo."
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <!-- Acciones -->
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Button
                            Content="Calcular"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CalcularCommand}"
                            AutomationProperties.Name="Calcular el análisis de signos" />
                        <Button
                            Content="Grabar"
                            Command="{x:Bind ViewModel.GrabarCommand}"
                            AutomationProperties.Name="Grabar el resultado a fichero" />
                        <Button
                            Content="Limpiar columna ganadora"
                            Command="{x:Bind ViewModel.LimpiarColumnaGanadoraCommand}"
                            AutomationProperties.Name="Reiniciar la columna ganadora" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Resultados del proceso -->
            <Border Grid.Row="3" Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Resultado del proceso"
                        Style="{StaticResource SectionHeaderTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.ColumnasProcesadasTexto, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.TiempoTexto, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    <TextBlock
                        Text="{x:Bind ViewModel.PremiosRemanentesTexto, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    <TextBlock
                        Text="La rejilla de recuentos por partido (1 / X / 2) se mostrará aquí tras migrar el motor de cálculo."
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </Grid>
    </ScrollViewer>
</Page>
