<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AnaCombiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="10,7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
            <TextBlock
                Text="Análisis de grupos en combinación"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Define un grupo de partidos, carga un fichero de columnas y cuenta cuántas encajan en cada combinación."
                Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Columna izquierda: definición del grupo y acciones -->
            <StackPanel Grid.Column="0" Spacing="6" Width="280">

                <!-- Fichero de entrada -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="Fichero de entrada"
                            Style="{StaticResource SectionHeaderTextBlockStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.FicheroEntrada, Mode=OneWay}"
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Content="Seleccionar fichero…"
                            Command="{x:Bind ViewModel.SeleccionarFicheroCommand}"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Seleccionar fichero de columnas a procesar" />
                    </StackPanel>
                </Border>

                <!-- Definición del grupo -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="Patrón del grupo (14 partidos)"
                            Style="{StaticResource SectionHeaderTextBlockStyle}" />
                        <TextBlock
                            Text="Por partido: 1 / X / 2 fija el signo, G lo añade al grupo, - lo ignora."
                            Style="{StaticResource SecondaryTextBlockStyle}" />

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Partidos}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:AnaCombiPartido">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind NumeroTexto}"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <ComboBox
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{x:Bind OpcionesSigno}"
                                            SelectedItem="{x:Bind Seleccion, Mode=TwoWay}"
                                            AutomationProperties.Name="Selección del partido" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid ColumnSpacing="12" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                Text="Fallos admitidos"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <NumberBox
                                Grid.Column="1"
                                Width="120"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.FallosAdmitidos, Mode=TwoWay}"
                                AutomationProperties.Name="Número de fallos admitidos" />
                        </Grid>

                        <Button
                            Content="Limpiar patrón"
                            Command="{x:Bind ViewModel.LimpiarCommand}"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Restablecer todos los partidos a sin selección" />
                    </StackPanel>
                </Border>

                <!-- Acciones de cálculo -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button
                                Content="Calcular"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.CalcularCommand}"
                                AutomationProperties.Name="Calcular combinaciones" />
                            <Button
                                Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar cálculo en curso" />
                        </StackPanel>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock
                                    Text="Procesadas"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.ProcesadasTexto, Mode=OneWay}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock
                                    Text="Tiempo"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.TiempoTexto, Mode=OneWay}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Columna derecha: resultados -->
            <Border
                Grid.Column="1"
                Style="{StaticResource AppCardStyle}"
                VerticalAlignment="Stretch">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Resultados"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Resultados}"
                        SelectionMode="None"
                        Background="{ThemeResource AppSurfaceBrush}">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Width="32"
                                        Text=""
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="Grupo"
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="Columnas"
                                        Style="{StaticResource CaptionTextBlockStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AnaCombiResultado">
                                <Grid ColumnSpacing="12" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        Grid.Column="0"
                                        Width="32"
                                        MinWidth="32"
                                        IsChecked="{x:Bind Seleccionado, Mode=TwoWay}"
                                        AutomationProperties.Name="Marcar grupo para grabar" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Grupo}"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas" />
                                    <TextBlock
                                        Grid.Column="2"
                                        Text="{x:Bind ColumnasTexto}"
                                        VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Grid.Row="2"
                        Content="Grabar resultados"
                        HorizontalAlignment="Right"
                        IsEnabled="{x:Bind ViewModel.PuedeGrabar, Mode=OneWay}"
                        Command="{x:Bind ViewModel.GrabarCommand}"
                        AutomationProperties.Name="Grabar columnas de los grupos seleccionados" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
