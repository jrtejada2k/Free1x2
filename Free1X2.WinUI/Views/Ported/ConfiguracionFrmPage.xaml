<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.ConfiguracionFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="20" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="Configuración" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Ajusta los parámetros del boleto, la puntuación y las preferencias del programa."
                       Foreground="{ThemeResource AppTextSecondaryBrush}" TextWrapping="Wrap" />

            <!-- ===== Configuración del boleto ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Configuración del boleto" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Nº de partidos en boleto" />
                        <NumberBox Grid.Row="0" Grid.Column="1" MinWidth="120"
                                   Value="{x:Bind ViewModel.NumPartidos, Mode=TwoWay}"
                                   Minimum="1" Maximum="15" SpinButtonPlacementMode="Inline"
                                   AutomationProperties.Name="Número de partidos en el boleto" />

                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                                   Text="Separador de partidos" />
                        <TextBox Grid.Row="1" Grid.Column="1" MinWidth="160"
                                 Text="{x:Bind ViewModel.Separador, Mode=TwoWay}"
                                 AutomationProperties.Name="Separador de partidos" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Desplazamiento de grupo/condición ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Desplazamiento de grupo/condición"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>
                    <NumberBox Grid.Column="1" MinWidth="120"
                               Value="{x:Bind ViewModel.Desplazamiento, Mode=TwoWay}"
                               Minimum="0" Maximum="99" SpinButtonPlacementMode="Inline"
                               AutomationProperties.Name="Desplazamiento de grupo o condición" />
                </Grid>
            </Border>

            <!-- ===== Puntuación en CPs ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Puntuación en CPs" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <NumberBox Header="Fijos" MinWidth="100"
                                   Value="{x:Bind ViewModel.ValorFijos, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Puntuación fijos" />
                        <NumberBox Header="Dobles" MinWidth="100"
                                   Value="{x:Bind ViewModel.ValorDobles, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Puntuación dobles" />
                        <NumberBox Header="Triples" MinWidth="100"
                                   Value="{x:Bind ViewModel.ValorTriples, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Puntuación triples" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Separador de porcentajes JB ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Separador de porcentajes JB" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Seis límites en orden estrictamente creciente."
                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <NumberBox MinWidth="72" Value="{x:Bind ViewModel.Jb1, Mode=TwoWay}"
                                   AutomationProperties.Name="Límite JB 1" />
                        <NumberBox MinWidth="72" Value="{x:Bind ViewModel.Jb2, Mode=TwoWay}"
                                   AutomationProperties.Name="Límite JB 2" />
                        <NumberBox MinWidth="72" Value="{x:Bind ViewModel.Jb3, Mode=TwoWay}"
                                   AutomationProperties.Name="Límite JB 3" />
                        <NumberBox MinWidth="72" Value="{x:Bind ViewModel.Jb4, Mode=TwoWay}"
                                   AutomationProperties.Name="Límite JB 4" />
                        <NumberBox MinWidth="72" Value="{x:Bind ViewModel.Jb5, Mode=TwoWay}"
                                   AutomationProperties.Name="Límite JB 5" />
                        <NumberBox MinWidth="72" Value="{x:Bind ViewModel.Jb6, Mode=TwoWay}"
                                   AutomationProperties.Name="Límite JB 6" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Parámetros LAE ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Parámetros LAE" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <NumberBox Grid.Row="0" Grid.Column="0" Header="Recaudación"
                                   Value="{x:Bind ViewModel.Recaudacion, Mode=TwoWay}"
                                   AutomationProperties.Name="Recaudación" />
                        <TextBox Grid.Row="0" Grid.Column="1" Header="Símbolo moneda" MaxLength="3"
                                 Text="{x:Bind ViewModel.SimboloMoneda, Mode=TwoWay}"
                                 AutomationProperties.Name="Símbolo de moneda" />

                        <NumberBox Grid.Row="1" Grid.Column="0" Header="Precio apuesta"
                                   Value="{x:Bind ViewModel.PrecioApuesta, Mode=TwoWay}"
                                   SmallChange="0.05"
                                   AutomationProperties.Name="Precio de apuesta" />
                        <NumberBox Grid.Row="1" Grid.Column="1" Header="% al 14"
                                   Value="{x:Bind ViewModel.PorcentajeAl14, Mode=TwoWay}"
                                   Minimum="0" Maximum="100"
                                   AutomationProperties.Name="Porcentaje destinado al premio de 14" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Preferencias generales ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Preferencias" Style="{StaticResource SubtitleTextBlockStyle}" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Comprobar actualizaciones al inicio"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Buscar nuevas versiones automáticamente al abrir el programa."
                                       Foreground="{ThemeResource AppTextSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.ComprobarActualizacionesAlInicio, Mode=TwoWay}"
                                      AutomationProperties.Name="Comprobar actualizaciones al inicio" />
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Pedir confirmación al salir"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="Mostrar una advertencia antes de cerrar la aplicación."
                                       Foreground="{ThemeResource AppTextSecondaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind ViewModel.PedirConfirmacionAlSalir, Mode=TwoWay}"
                                      AutomationProperties.Name="Pedir confirmación al salir" />
                    </Grid>

                    <StackPanel Spacing="6" MaxWidth="240" HorizontalAlignment="Left">
                        <TextBlock Text="Idioma" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <ComboBox HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.Idiomas}"
                                  SelectedItem="{x:Bind ViewModel.IdiomaSeleccionado, Mode=TwoWay}"
                                  AutomationProperties.Name="Idioma" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Acciones ===== -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Guardar" Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.GuardarCommand}"
                        AutomationProperties.Name="Guardar configuración" />
                <Button Content="Volver"
                        Click="VolverButton_Click"
                        AutomationProperties.Name="Volver" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
