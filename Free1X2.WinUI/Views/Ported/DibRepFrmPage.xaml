<Page
    x:Class="Free1X2.WinUI.Views.Ported.DibRepFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <ScrollViewer Padding="24" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">

            <!-- Encabezado: titulo real del form legacy (this.Text = "coincidencias") -->
            <TextBlock
                Text="Coincidencias"
                Style="{StaticResource PageTitleTextBlockStyle}" />

            <TextBlock
                Text="Distribución de coincidencias por posición de la quiniela."
                Style="{StaticResource SecondaryTextBlockStyle}" />

            <!-- Resumen + control de modo (GroupBox "mostrar" del form legacy) -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">

                    <TextBlock
                        Text="Mostrar"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock
                            Text="Columnas totales:"
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.NumColumnasTexto, Mode=OneWay}"
                            VerticalAlignment="Center"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </StackPanel>

                    <!-- rbPercent / rbCols del legacy: porcentajes (On) vs columnas (Off) -->
                    <ToggleSwitch
                        Header="Modo de visualización"
                        OnContent="Porcentajes"
                        OffContent="Columnas (conteo)"
                        IsOn="{x:Bind ViewModel.MostrarPorcentajes, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Tabla de coincidencias: 15 columnas (posiciones 0..14) x filas de categoria -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">

                    <TextBlock
                        Text="Posiciones"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="6">

                            <!-- Fila de encabezados de columna (0..14) -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.EncabezadosColumnas}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border
                                            Width="48"
                                            Height="28"
                                            Background="{ThemeResource AppSurfaceAltBrush}"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4">
                                            <TextBlock
                                                Text="{x:Bind}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Filas de datos -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Filas}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:FilaCoincidencias">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">

                                            <!-- Etiqueta de fila (cant. 1 / cant. X / cant. 2 / cant. V / posiciones) -->
                                            <Border
                                                Width="96"
                                                Height="28"
                                                Background="{ThemeResource AppSurfaceAltBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                                <TextBlock
                                                    Text="{x:Bind Etiqueta}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Foreground="{ThemeResource AppTextBrush}" />
                                            </Border>

                                            <!-- 15 celdas de la fila -->
                                            <ItemsControl ItemsSource="{x:Bind Celdas}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="4" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <Border
                                                            Width="48"
                                                            Height="28"
                                                            Background="{ThemeResource AppSurfaceBrush}"
                                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4">
                                                            <TextBlock
                                                                Text="{x:Bind}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Style="{StaticResource CaptionTextBlockStyle}"
                                                                Foreground="{ThemeResource AppTextBrush}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
