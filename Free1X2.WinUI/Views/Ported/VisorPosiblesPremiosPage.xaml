<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.VisorPosiblesPremiosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    x:Name="PageRoot"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="Visor de Posibles Premios"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Recorre los grupos calculados. Cada grupo muestra su columna ganadora y las columnas jugadas que optan a premio (16/15/14/13/12/11/10 aciertos)."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Navegación entre grupos (legacy: btnAtras '<', lblContador, btnAdelante '>') -->
        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button
                    Content="&#x25C0;"
                    Command="{x:Bind ViewModel.AtrasCommand}"
                    AutomationProperties.Name="Grupo anterior" />
                <TextBlock
                    Text="{x:Bind ViewModel.Contador, Mode=OneWay}"
                    VerticalAlignment="Center"
                    MinWidth="80"
                    TextAlignment="Center"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Foreground="{ThemeResource AppTextBrush}" />
                <Button
                    Content="&#x25B6;"
                    Command="{x:Bind ViewModel.AdelanteCommand}"
                    AutomationProperties.Name="Grupo siguiente" />
            </StackPanel>
        </Border>

        <!-- Contenido del grupo: columna ganadora + columnas premiadas -->
        <ScrollViewer Grid.Row="2"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Auto">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Columna ganadora (legacy: CG / lblCG1..lblCG16 en vertical) -->
                <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Columna ganadora (CG)"
                            Style="{StaticResource SectionHeaderTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnaGanadora, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" Spacing="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:SignoGanadorItem">
                                    <Border
                                        Width="28" Height="28"
                                        Background="{ThemeResource AppSurfaceAltBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                        <TextBlock
                                            Text="{x:Bind Signo}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            Foreground="{ThemeResource AppTextBrush}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Columnas jugadas que optan a premio (legacy: ControlPosiblesPremios horizontal en cctrl) -->
                <Border Grid.Column="1" Style="{StaticResource AppCardStyle}" VerticalAlignment="Top">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Text="Columnas con premio"
                            Style="{StaticResource SectionHeaderTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                        <TextBlock
                            Text="Cada bloque es una columna jugada del grupo; la etiqueta superior indica la categoría de premio a la que opta."
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            Foreground="{ThemeResource AppTextSecondaryBrush}" />

                        <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnasPremiadas, Mode=OneWay}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:ColumnaPremioItem">
                                    <Border
                                        Background="{ThemeResource AppSurfaceBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="6">
                                        <StackPanel Spacing="4">
                                            <Border
                                                Background="{ThemeResource AppSurfaceAltBrush}"
                                                CornerRadius="2"
                                                Padding="2">
                                                <TextBlock
                                                    Text="{x:Bind CategoriaTexto}"
                                                    HorizontalAlignment="Center"
                                                    Style="{StaticResource CaptionTextBlockStyle}"
                                                    Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                            </Border>
                                            <ItemsControl ItemsSource="{x:Bind Signos}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Vertical" Spacing="4" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <Border
                                                            Width="24" Height="24"
                                                            Background="{ThemeResource AppSurfaceAltBrush}"
                                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="2">
                                                            <TextBlock
                                                                Text="{x:Bind}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontFamily="Consolas"
                                                                Foreground="{ThemeResource AppTextBrush}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
