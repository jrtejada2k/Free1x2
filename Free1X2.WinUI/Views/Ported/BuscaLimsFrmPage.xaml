<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.BuscaLimsFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="820" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Buscador límites" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Recorre todas las columnas y calcula los valores mínimo y máximo de Sumas y Productos para las que aciertan dentro del rango indicado."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Tabla de valoraciones (control legacy 'valors') ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Valoraciones por partido" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Origen de datos del control 'valors' (valoraciones 1 / X / 2 por partido). La carga y edición de la rejilla se portará por separado."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />
                    <!-- TODO: Dominio legacy — control Free1X2.UI.Controls.valors (rejilla de valoraciones por partido).
                         Provee dv = valors1.RetVals() usado por BuscaLimsFrm.Calcular(). -->
                </StackPanel>
            </Border>

            <!-- ===== Parámetros de búsqueda ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Parámetros" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rango"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 4-9"
                                 Text="{x:Bind ViewModel.RangoAciertos, Mode=TwoWay}"
                                 AutomationProperties.Name="Rango de aciertos permitidos respecto a la columna base" />
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="C.B."
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.ColumnaBase, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                    </Grid>

                    <Button Content="Calcular Límites"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.CalcularCommand}"
                            AutomationProperties.Name="Calcular los límites de sumas y productos" />
                </StackPanel>
            </Border>

            <!-- ===== Resultados (GroupBox 'Resultados' legacy) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Resultados" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Cabeceras Mín / Máx -->
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Mín"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Máx"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />

                        <!-- Sumas -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Sumas"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 Text="{x:Bind ViewModel.SumaMin, Mode=OneWay}"
                                 AutomationProperties.Name="Suma mínima" />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 Text="{x:Bind ViewModel.SumaMax, Mode=OneWay}"
                                 AutomationProperties.Name="Suma máxima" />

                        <!-- Productos -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Productos"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 Text="{x:Bind ViewModel.ProductoMin, Mode=OneWay}"
                                 AutomationProperties.Name="Producto mínimo" />
                        <TextBox Grid.Row="2" Grid.Column="2"
                                 IsReadOnly="True"
                                 TextAlignment="Center"
                                 Text="{x:Bind ViewModel.ProductoMax, Mode=OneWay}"
                                 AutomationProperties.Name="Producto máximo" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Estado del proceso (lColProc / lColAdm / lTime) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Proceso" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Procesadas" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ColumnasProcesadas, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Admitidas" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ColumnasAdmitidas, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Tiempo" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.Tiempo, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
