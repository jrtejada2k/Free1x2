<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.ConfiguracionAnalisisFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Padding="32,32,32,8" Spacing="4">
            <TextBlock Text="Configurar Análisis" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="Selecciona qué tipos de análisis estadístico se ejecutarán sobre los históricos."
                       Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Contenido desplazable -->
        <ScrollViewer Grid.Row="1" Padding="32,8,32,8" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">

                <!-- Acciones rápidas: Todo / Nada -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="Marcar todo"
                            Command="{x:Bind ViewModel.MarcarTodoCommand}"
                            AutomationProperties.Name="Marcar todas las opciones de análisis" />
                    <Button Content="Desmarcar todo"
                            Command="{x:Bind ViewModel.DesmarcarTodoCommand}"
                            AutomationProperties.Name="Desmarcar todas las opciones de análisis" />
                </StackPanel>

                <!-- Tarjeta: análisis de signos -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Signos y secuencias" Style="{StaticResource CardTitleTextBlockStyle}" />

                        <ToggleSwitch Header="VX2"
                                      IsOn="{x:Bind ViewModel.VX2, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar VX2" />

                        <ToggleSwitch Header="Signos seguidos"
                                      IsOn="{x:Bind ViewModel.Seguidos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar signos seguidos" />

                        <ToggleSwitch Header="Figuras V1X2" Margin="24,0,0,0"
                                      IsOn="{x:Bind ViewModel.FigurasV1X2, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.FigurasV1X2Habilitado, Mode=OneWay}"
                                      AutomationProperties.Name="Analizar figuras V1X2 (requiere signos seguidos)" />

                        <ToggleSwitch Header="Dibujos"
                                      IsOn="{x:Bind ViewModel.Dibujos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar dibujos" />

                        <ToggleSwitch Header="Interrupciones"
                                      IsOn="{x:Bind ViewModel.Interrupciones, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar interrupciones" />

                        <ToggleSwitch Header="Simetrías"
                                      IsOn="{x:Bind ViewModel.Simetrias, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar simetrías" />

                        <ToggleSwitch Header="Diferencias"
                                      IsOn="{x:Bind ViewModel.Diferencias, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar diferencias" />
                    </StackPanel>
                </Border>

                <!-- Tarjeta: formatos y grupos -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Formatos y grupos" Style="{StaticResource CardTitleTextBlockStyle}" />

                        <ToggleSwitch Header="Grupos equipos"
                                      IsOn="{x:Bind ViewModel.GruposEquipos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar grupos de equipos" />

                        <ToggleSwitch Header="Formatos"
                                      IsOn="{x:Bind ViewModel.Formatos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar formatos" />

                        <ToggleSwitch Header="Formatos 123"
                                      IsOn="{x:Bind ViewModel.Formatos123, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar formatos 123" />

                        <ToggleSwitch Header="Control de grupos"
                                      IsOn="{x:Bind ViewModel.ControlGrupos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar control de grupos" />

                        <ToggleSwitch Header="Control de conjuntos"
                                      IsOn="{x:Bind ViewModel.ControlConjuntos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar control de conjuntos" />
                    </StackPanel>
                </Border>

                <!-- Tarjeta: pesos y valoración -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Pesos y valoración" Style="{StaticResource CardTitleTextBlockStyle}" />

                        <ToggleSwitch Header="Pesos numéricos"
                                      IsOn="{x:Bind ViewModel.Pesos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar pesos numéricos" />

                        <ToggleSwitch Header="Figuras de pesos numéricos" Margin="24,0,0,0"
                                      IsOn="{x:Bind ViewModel.FigurasPesos, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.FigurasPesosHabilitado, Mode=OneWay}"
                                      AutomationProperties.Name="Analizar figuras de pesos numéricos (requiere pesos numéricos)" />

                        <ToggleSwitch Header="Valoración"
                                      IsOn="{x:Bind ViewModel.Valoracion, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar valoración" />

                        <ToggleSwitch Header="Columnas probables"
                                      IsOn="{x:Bind ViewModel.ColumnasProbables, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar columnas probables" />

                        <ToggleSwitch Header="Distancias"
                                      IsOn="{x:Bind ViewModel.Distancias, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar distancias" />
                    </StackPanel>
                </Border>

                <!-- Tarjeta: contactos -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Contactos" Style="{StaticResource CardTitleTextBlockStyle}" />

                        <ToggleSwitch Header="Contactos"
                                      IsOn="{x:Bind ViewModel.Contactos, Mode=TwoWay}"
                                      AutomationProperties.Name="Analizar contactos" />

                        <ToggleSwitch Header="Figuras de contactos" Margin="24,0,0,0"
                                      IsOn="{x:Bind ViewModel.FigurasContactos, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.FigurasContactosHabilitado, Mode=OneWay}"
                                      AutomationProperties.Name="Analizar figuras de contactos (requiere contactos)" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Barra de acciones -->
        <Border Grid.Row="2" Padding="32,16"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Salir" Click="BtnSalir_Click"
                        AutomationProperties.Name="Salir sin guardar" />
                <Button Content="Guardar" Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.GuardarCommand}"
                        Click="BtnGuardar_Click"
                        AutomationProperties.Name="Guardar configuración de análisis" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
