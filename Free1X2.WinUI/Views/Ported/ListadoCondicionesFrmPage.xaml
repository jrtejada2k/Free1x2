<Page
    x:Class="Free1X2.WinUI.Views.Ported.ListadoCondicionesFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ported="using:Free1X2.WinUI.Views.Ported"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado con el título real del form legacy -->
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource PageTitleTextBlockStyle}"
            Text="Listado de Condiciones" />

        <!-- Barra de acciones (botones legacy: Expandir/Colapsar/Exportar) -->
        <StackPanel
            Grid.Row="1"
            Margin="0,16,0,16"
            Orientation="Horizontal"
            Spacing="8">
            <Button
                Command="{x:Bind ViewModel.ExpandirTodoCommand}"
                Content="Expandir Todo" />
            <Button
                Command="{x:Bind ViewModel.ColapsarTodoCommand}"
                Content="Colapsar Todo" />
            <Button
                Command="{x:Bind ViewModel.ExportarTextoCommand}"
                Content="Exportar a Texto" />
            <Button
                Command="{x:Bind ViewModel.ExportarHtmlCommand}"
                Content="Exportar a Html" />
        </StackPanel>

        <!-- Árbol de condiciones (equivalente del TreeView legacy) -->
        <Border
            Grid.Row="2"
            Style="{StaticResource AppCardStyle}">
            <TreeView
                ItemsSource="{x:Bind ViewModel.Condiciones}"
                SelectionMode="Single">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="ported:CondicionNodo">
                        <TreeViewItem
                            ItemsSource="{x:Bind Hijos}"
                            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}">
                            <TextBlock
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind Texto}" />
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>
    </Grid>
</Page>
