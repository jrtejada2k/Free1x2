<Page
    x:Class="Free1X2.WinUI.Views.Ported.RotacionDeSignosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Margin="12,8" Spacing="4">
            <TextBlock Text="Rotación de signos" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Transforma los signos (1 / X / 2) de un fichero de columnas según una tabla de cambios y genera un fichero de salida."
                Style="{StaticResource SecondaryTextBlockStyle}"
                TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Padding="10,7">
            <StackPanel Spacing="6">

                <!-- Ficheros -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Ficheros" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Fichero de entrada" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Grid.Column="0"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.FicheroEntrada, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    Content="Examinar…"
                                    Command="{x:Bind ViewModel.SeleccionarEntradaCommand}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Fichero de salida" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Grid.Column="0"
                                    IsReadOnly="True"
                                    Text="{x:Bind ViewModel.FicheroSalida, Mode=OneWay}" />
                                <Button
                                    Grid.Column="1"
                                    Content="Examinar…"
                                    Command="{x:Bind ViewModel.SeleccionarSalidaCommand}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Cambios de signo -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Cambios de signo" Style="{StaticResource SectionHeaderTextBlockStyle}" />
                        <TextBlock
                            Text="Para cada partido de la columna base, define en qué signo se transforma cada 1, X y 2."
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            TextWrapping="Wrap" />

                        <!-- Cabecera de columnas -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Part." Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Grid.Column="1" Text="Base" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Grid.Column="2" Text="1 →" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Grid.Column="3" Text="X →" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Grid.Column="4" Text="2 →" Style="{StaticResource CaptionTextBlockStyle}" />
                        </Grid>

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Filas}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:FilaRotacionViewModel">
                                    <Grid ColumnSpacing="8" Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            Text="{x:Bind NumeroTexto}"
                                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <ComboBox
                                            Grid.Column="1"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{x:Bind OpcionesSigno}"
                                            SelectedItem="{x:Bind SignoBase, Mode=TwoWay}" />
                                        <ComboBox
                                            Grid.Column="2"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{x:Bind OpcionesSigno}"
                                            SelectedItem="{x:Bind NuevoUno, Mode=TwoWay}" />
                                        <ComboBox
                                            Grid.Column="3"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{x:Bind OpcionesSigno}"
                                            SelectedItem="{x:Bind NuevaX, Mode=TwoWay}" />
                                        <ComboBox
                                            Grid.Column="4"
                                            HorizontalAlignment="Stretch"
                                            ItemsSource="{x:Bind OpcionesSigno}"
                                            SelectedItem="{x:Bind NuevoDos, Mode=TwoWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Opciones -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Opciones" Style="{StaticResource SectionHeaderTextBlockStyle}" />
                        <ToggleSwitch
                            Header="Corrección de fallos"
                            OnContent="Activada"
                            OffContent="Desactivada"
                            IsOn="{x:Bind ViewModel.CorreccionDeFallos, Mode=TwoWay}" />
                        <Button
                            Content="Transponer"
                            Command="{x:Bind ViewModel.TransponerCommand}" />
                        <TextBlock
                            Text="Nota: las valoraciones de JORNADA y COMBINACIÓN (ControlPorcentajes legacy) se portarán como control propio en una fase posterior."
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Pie: estado + acciones -->
        <Grid Grid.Row="2" Padding="10,7" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{x:Bind ViewModel.EstadoTexto, Mode=OneWay}"
                Style="{StaticResource SecondaryTextBlockStyle}" />
            <Button
                Grid.Column="1"
                Content="Aceptar"
                Style="{StaticResource AccentButtonStyle}"
                IsEnabled="{x:Bind ViewModel.PuedeCalcular, Mode=OneWay}"
                Command="{x:Bind ViewModel.AceptarCommand}" />
            <Button
                Grid.Column="2"
                Content="Cancelar"
                Command="{x:Bind ViewModel.CancelarCommand}" />
        </Grid>
    </Grid>
</Page>
