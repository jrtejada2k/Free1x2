<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.DibujosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== Encabezado ===== -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Dibujos X+2" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"
                       Text="Filtra las columnas por la figura formada por el número de X y el número de 2." />
        </StackPanel>

        <!-- ===== Ayuda + acciones de selección ===== -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="12,10">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE946;" FontSize="18"
                              Foreground="{ThemeResource AppAccentBrush}" />
                    <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                               Text="Un dibujo es la figura formada por el número de X y el número de 2. Por ejemplo: 2 equis y 3 doses forman el dibujo 2+3." />
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center">
                <Button Content="Marcar todos"
                        Command="{x:Bind ViewModel.MarcarTodosCommand}"
                        AutomationProperties.Name="Marcar todos los dibujos" />
                <Button Content="Desmarcar todos"
                        Command="{x:Bind ViewModel.DesmarcarTodosCommand}"
                        AutomationProperties.Name="Desmarcar todos los dibujos" />
            </StackPanel>
        </Grid>

        <!-- ===== Malla de dibujos X+2 ===== -->
        <Border Grid.Row="2" Style="{StaticResource AppCardStyle}" Padding="12">
            <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
                <controls:ItemsRepeater ItemsSource="{x:Bind ViewModel.Dibujos}">
                    <controls:ItemsRepeater.Layout>
                        <controls:UniformGridLayout
                            MinItemWidth="64"
                            MinItemHeight="40"
                            MinColumnSpacing="6"
                            MinRowSpacing="6"
                            ItemsStretch="Fill" />
                    </controls:ItemsRepeater.Layout>
                    <controls:ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="local:DibujoCeldaViewModel">
                            <ToggleButton
                                Content="{x:Bind Etiqueta}"
                                IsChecked="{x:Bind Seleccionado, Mode=TwoWay}"
                                Style="{StaticResource SignoToggleButtonStyle}"
                                AutomationProperties.Name="{x:Bind Etiqueta}"
                                ToolTipService.ToolTip="{x:Bind Etiqueta}" />
                        </DataTemplate>
                    </controls:ItemsRepeater.ItemTemplate>
                </controls:ItemsRepeater>
            </ScrollViewer>
        </Border>

        <!-- ===== Barra de condición (equivale a MenuCondiciones) ===== -->
        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{x:Bind ViewModel.Resumen, Mode=OneWay}"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Content="Estadísticas"
                        Command="{x:Bind ViewModel.EstadisticasCommand}"
                        AutomationProperties.Name="Ver estadísticas del filtro" />
                <Button Content="Abrir"
                        Command="{x:Bind ViewModel.AbrirCommand}"
                        AutomationProperties.Name="Abrir condición de dibujos" />
                <Button Content="Guardar"
                        Command="{x:Bind ViewModel.GuardarCommand}"
                        AutomationProperties.Name="Guardar condición de dibujos" />
                <Button Content="Borrar"
                        Command="{x:Bind ViewModel.BorrarCommand}"
                        AutomationProperties.Name="Borrar datos del filtro" />
                <Button Content="Cancelar"
                        Command="{x:Bind ViewModel.CancelarCommand}"
                        AutomationProperties.Name="Cancelar" />
                <Button Content="Aceptar"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.AceptarCommand}"
                        AutomationProperties.Name="Aceptar y aplicar el filtro" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
