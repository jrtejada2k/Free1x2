<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.DistanciasFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="820" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Distancias" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Distancia: número máximo de partidos que separan dos signos iguales."
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

            <!-- ===== Valores de distancia por tipo de signo ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Valores admitidos (0–15)" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Introduce las distancias permitidas para cada tipo de signo. Separa varios valores con espacios o comas."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <!-- Var -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Var"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.DistanciasVar, Mode=TwoWay}"
                                 AutomationProperties.Name="Distancias para cualquier signo (Var)" />
                    </Grid>

                    <!-- 1 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.Distancias1, Mode=TwoWay}"
                                 AutomationProperties.Name="Distancias para el signo 1" />
                    </Grid>

                    <!-- X -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.DistanciasX, Mode=TwoWay}"
                                 AutomationProperties.Name="Distancias para el signo X" />
                    </Grid>

                    <!-- 2 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.Distancias2, Mode=TwoWay}"
                                 AutomationProperties.Name="Distancias para el signo 2" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Acciones (menuCondiciones del form legacy) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Acciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Aceptar"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.AceptarCommand}"
                                AutomationProperties.Name="Aceptar y aplicar el filtro de distancias" />
                        <Button Content="Estadísticas"
                                Command="{x:Bind ViewModel.EstadisticasCommand}"
                                AutomationProperties.Name="Ver estadísticas del filtro" />
                        <Button Content="Guardar"
                                Command="{x:Bind ViewModel.GuardarCommand}"
                                AutomationProperties.Name="Guardar la condición en un archivo" />
                        <Button Content="Abrir"
                                Command="{x:Bind ViewModel.AbrirCommand}"
                                AutomationProperties.Name="Abrir una condición desde un archivo" />
                        <Button Content="Borrar"
                                Command="{x:Bind ViewModel.BorrarCommand}"
                                AutomationProperties.Name="Borrar todos los valores" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
