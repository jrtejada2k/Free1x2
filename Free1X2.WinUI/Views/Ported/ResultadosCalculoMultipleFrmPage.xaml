<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.ResultadosCalculoMultipleFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="10,7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
            <TextBlock
                Text="Resultados de la Generación Múltiple"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Resumen de cada cálculo realizado en lote: fichero de combinación, fichero de columnas generado, columnas analizadas, columnas aceptadas y tiempo invertido."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Tarjeta con el listado de resultados -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Cabecera de columnas (legacy ListView.Columns) -->
                <Grid Grid.Row="0" Padding="12,0,12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Arch. Combinación"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="1" Text="Arch. Columnas"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="2" Text="Cols. Analizadas"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="3" Text="Cols. Aceptadas"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="4" Text="Tiempo"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                </Grid>

                <!-- Filas de resultados (legacy ListView.Items, solo lectura) -->
                <ListView
                    x:Name="ListaResumen"
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Resultados, Mode=OneWay}"
                    SelectionMode="Single"
                    AutomationProperties.Name="Resumen de la generación múltiple">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ResultadoCalculoMultipleItem">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind ArchivoCombinacion}"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ArchivoColumnas}"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind ColumnasAnalizadas}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="3" Text="{x:Bind ColumnasAceptadas}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="4" Text="{x:Bind Tiempo}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
