<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.TriosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="900" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Tríos" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Analiza un fichero de columnas de entrada validando cada columna contra una tabla de límites de cinco niveles. Cuenta las columnas procesadas y válidas, y muestra un resultado por nivel."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Tabla de Límites (GroupBox 'Límites' legacy: c11..c52 + r1..r5) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Límites" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Mínimo y máximo de aciertos admitidos por nivel (campos legacy c11/c12 … c51/c52)."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <Grid ColumnSpacing="16" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Cabeceras -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Niv"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Mín"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Máx"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Resultado"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />

                        <!-- Nivel 1 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="1" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel1Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 1" />
                        <NumberBox Grid.Row="1" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel1Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 1" />
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel1, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 2 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="2" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel2Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 2" />
                        <NumberBox Grid.Row="2" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel2Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 2" />
                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel2, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 3 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="3"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="3" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel3Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 3" />
                        <NumberBox Grid.Row="3" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel3Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 3" />
                        <TextBlock Grid.Row="3" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel3, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 4 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="4"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="4" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel4Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 4" />
                        <NumberBox Grid.Row="4" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel4Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 4" />
                        <TextBlock Grid.Row="4" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel4, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 5 -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="5"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="5" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel5Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 5" />
                        <NumberBox Grid.Row="5" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel5Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 5" />
                        <TextBlock Grid.Row="5" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel5, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Matriz de Niveles (GroupBox 'Niveles' legacy: v###/p##/va##/vb##) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Niveles" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Matriz de valores calculados por trío y combinación de signos (1·· / X·· / 2·· × xx / x1 / 12 / 1x / 11 / 22 / 2x / 21 / x2). Es de sólo lectura y se rellena durante el cálculo."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />
                    <!-- TODO: Dominio legacy — la rejilla de Niveles del WinForms TriosFrm está formada por
                         cientos de TextBox de sólo lectura (campos v011..v939, p01..p73, va11..vb39) volcados
                         en la matriz 'nivells' por RecuperarPantalla() y recalculados durante Calcular().
                         Se portará como un control de rejilla dedicado en una iteración posterior. -->
                </StackPanel>
            </Border>

            <!-- ===== Acciones (botones bCalcular / bAnalizar / bGrabar / bLeer / bSalvar / bCancelar) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Acciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Calcular"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.CalcularCommand}"
                                AutomationProperties.Name="Calcular los tríos a partir de un fichero de columnas" />
                        <Button Content="Analizar"
                                Command="{x:Bind ViewModel.AnalizarCommand}"
                                AutomationProperties.Name="Analizar y mostrar el resultado por nivel" />
                        <Button Content="Grabar Resultado"
                                Command="{x:Bind ViewModel.GrabarCommand}"
                                AutomationProperties.Name="Grabar las columnas válidas a fichero" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Abrir Condiciones"
                                Command="{x:Bind ViewModel.AbrirCondicionesCommand}"
                                AutomationProperties.Name="Abrir condiciones desde fichero" />
                        <Button Content="Salvar Condiciones"
                                Command="{x:Bind ViewModel.SalvarCondicionesCommand}"
                                AutomationProperties.Name="Salvar condiciones a fichero" />
                        <Button Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar el cálculo en curso" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Estado del proceso (etiquetas lproc / lval / ltime) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Proceso" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Procesadas" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ColumnasProcesadas, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Válidas" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ColumnasValidas, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Tiempo" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.Tiempo, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
