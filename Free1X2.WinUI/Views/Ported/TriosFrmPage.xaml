<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.TriosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ported="using:Free1X2.WinUI.Views.Ported">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="900" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Tríos" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Analiza un fichero de columnas de entrada validando cada columna contra una tabla de límites de cinco niveles. Cuenta las columnas procesadas y válidas, y muestra un resultado por nivel."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Tabla de Límites (GroupBox 'Límites' legacy: c11..c52 + r1..r5) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Límites" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Mínimo y máximo de aciertos admitidos por nivel (campos legacy c11/c12 … c51/c52)."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <Grid ColumnSpacing="16" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Cabeceras -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Niv"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Mín"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Máx"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Resultado"
                                   HorizontalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />

                        <!-- Nivel 1 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="1" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel1Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 1" />
                        <NumberBox Grid.Row="1" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel1Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 1" />
                        <TextBlock Grid.Row="1" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel1, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 2 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="2" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel2Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 2" />
                        <NumberBox Grid.Row="2" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel2Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 2" />
                        <TextBlock Grid.Row="2" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel2, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 3 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="3"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="3" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel3Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 3" />
                        <NumberBox Grid.Row="3" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel3Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 3" />
                        <TextBlock Grid.Row="3" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel3, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 4 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="4"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="4" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel4Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 4" />
                        <NumberBox Grid.Row="4" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel4Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 4" />
                        <TextBlock Grid.Row="4" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel4, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />

                        <!-- Nivel 5 -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="5"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <NumberBox Grid.Row="5" Grid.Column="1"
                                   Value="{x:Bind ViewModel.Nivel5Min, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Mínimo del nivel 5" />
                        <NumberBox Grid.Row="5" Grid.Column="2"
                                   Value="{x:Bind ViewModel.Nivel5Max, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Máximo del nivel 5" />
                        <TextBlock Grid.Row="5" Grid.Column="3"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.ResultadoNivel5, Mode=OneWay}"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Matriz de Niveles (GroupBox 'Niveles' legacy: v###/p##/va##/vb##) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Niveles" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="12 tríos: las 3 primeras columnas son los partidos que forman el trío (1-based); las 27 restantes asignan el nivel (1-5) a cada combinación de signos del trío. RecuperarPantalla() vuelca esta rejilla a la matriz nivells[12,30] que usa Valida()."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <ScrollViewer HorizontalScrollMode="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollMode="Disabled"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="4">
                            <!-- Cabecera: posiciones del trío + 27 combinaciones de signos -->
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="P1" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="P2" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="P3" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="111" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="11X" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="112" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="1X1" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="1XX" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="1X2" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="121" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="12X" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="122" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="X11" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="X1X" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="X12" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="XX1" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="XXX" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="XX2" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="X21" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="X2X" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="X22" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="211" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="21X" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="212" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="2X1" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="2XX" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="2X2" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="221" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="22X" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                                <TextBlock Text="222" Width="40" TextAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                            </StackPanel>

                            <!-- 12 filas editables (NivelRowItem). Cada celda es un TextBox compacto. -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Niveles, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="ported:NivelRowItem">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,2">
                                            <TextBox Width="40" Text="{x:Bind Pos1, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind Pos2, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind Pos3, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V0, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V1, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V2, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V3, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V4, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V5, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V6, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V7, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V8, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V9, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V10, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V11, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V12, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V13, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V14, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V15, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V16, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V17, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V18, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V19, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V20, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V21, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V22, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V23, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V24, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V25, Mode=TwoWay}" />
                                            <TextBox Width="40" Text="{x:Bind V26, Mode=TwoWay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- ===== Acciones (botones bCalcular / bAnalizar / bGrabar / bLeer / bSalvar / bCancelar) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Acciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Calcular"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.CalcularCommand}"
                                AutomationProperties.Name="Calcular los tríos a partir de un fichero de columnas" />
                        <Button Content="Analizar"
                                Command="{x:Bind ViewModel.AnalizarCommand}"
                                AutomationProperties.Name="Analizar y mostrar el resultado por nivel" />
                        <Button Content="Grabar Resultado"
                                Command="{x:Bind ViewModel.GrabarCommand}"
                                AutomationProperties.Name="Grabar las columnas válidas a fichero" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Abrir Condiciones"
                                Command="{x:Bind ViewModel.AbrirCondicionesCommand}"
                                AutomationProperties.Name="Abrir condiciones desde fichero" />
                        <Button Content="Salvar Condiciones"
                                Command="{x:Bind ViewModel.SalvarCondicionesCommand}"
                                AutomationProperties.Name="Salvar condiciones a fichero" />
                        <Button Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar el cálculo en curso" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Estado del proceso (etiquetas lproc / lval / ltime) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Proceso" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Procesadas" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ColumnasProcesadas, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="Válidas" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.ColumnasValidas, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="Tiempo" Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.Tiempo, Mode=OneWay}"
                                       Style="{StaticResource CardTitleTextBlockStyle}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
