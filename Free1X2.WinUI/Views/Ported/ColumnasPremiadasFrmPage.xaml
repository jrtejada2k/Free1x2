<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.ColumnasPremiadasFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="10,7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
            <TextBlock
                Text="Columnas Premiadas"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Resumen de las columnas premiadas encontradas. Puedes exportar todas las columnas o solo las seleccionadas a un fichero de texto."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Tarjeta con el listado de resultados -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Cabecera de columnas (legacy ListView.Columns) -->
                <Grid Grid.Row="0" Padding="12,0,12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="0.6*" />
                        <ColumnDefinition Width="1.8*" />
                        <ColumnDefinition Width="0.7*" />
                        <ColumnDefinition Width="0.7*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Arch. Columnas"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="1" Text="Jorn."
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="2" Text="Columna"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="3" Text="Premio"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="4" Text="Nº Col."
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="5" Text="Nº Boleto"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                </Grid>

                <!-- Filas de resultados (legacy ListView.Items, multi-selección) -->
                <ListView
                    x:Name="ListaResumen"
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Columnas, Mode=OneWay}"
                    SelectionMode="Extended"
                    IsMultiSelectCheckBoxEnabled="True"
                    AutomationProperties.Name="Listado de columnas premiadas">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ColumnaPremiadaItem">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.2*" />
                                    <ColumnDefinition Width="0.6*" />
                                    <ColumnDefinition Width="1.8*" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind ArchivoColumnas}"
                                    TextTrimming="CharacterEllipsis"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Jornada}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Columna}"
                                    FontFamily="Consolas"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="3" Text="{x:Bind Premio}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="4" Text="{x:Bind NumeroColumna}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <TextBlock Grid.Column="5" Text="{x:Bind NumeroBoleto}"
                                    Foreground="{ThemeResource AppTextBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Acciones (legacy btnGuardarTodas / btnGuardarSeleccionadas) -->
        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="5"
            HorizontalAlignment="Right"
            Margin="0,8,0,0">
            <Button
                Content="Guardar Todas"
                Command="{x:Bind ViewModel.GuardarTodasCommand}"
                AutomationProperties.Name="Guardar todas las columnas en un fichero" />
            <Button
                Content="Guardar Seleccionadas"
                Style="{StaticResource AccentButtonStyle}"
                Click="OnGuardarSeleccionadasClick"
                AutomationProperties.Name="Guardar las columnas seleccionadas en un fichero" />
        </StackPanel>
    </Grid>
</Page>
