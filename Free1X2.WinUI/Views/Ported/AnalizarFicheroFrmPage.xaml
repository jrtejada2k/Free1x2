<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AnalizarFicheroFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="Analizar fichero de columnas"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Selecciona un fichero de columnas (.txt / .cols) y lanza el análisis de la combinación."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Tarjeta de parámetros -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}"
            VerticalAlignment="Top"
            MaxWidth="560"
            HorizontalAlignment="Left">
            <StackPanel Spacing="16">

                <!-- Fichero de entrada -->
                <StackPanel Spacing="6">
                    <TextBlock
                        Text="Nombre del fichero de columnas"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            PlaceholderText="Ruta del fichero de columnas"
                            Text="{x:Bind ViewModel.FicheroEntrada, Mode=TwoWay}"
                            AutomationProperties.Name="Ruta del fichero de columnas" />
                        <Button
                            Grid.Column="1"
                            Content="Examinar…"
                            Command="{x:Bind ViewModel.AbrirFicheroCommand}"
                            AutomationProperties.Name="Examinar y seleccionar fichero de columnas" />
                    </Grid>
                    <TextBlock
                        Text="{x:Bind ViewModel.ResumenColumnas, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                </StackPanel>

                <!-- Opción de pleno -->
                <ToggleSwitch
                    Header="Incluir pleno al 15"
                    OffContent="No"
                    OnContent="Sí"
                    IsEnabled="{x:Bind ViewModel.PuedeIncluirPleno, Mode=OneWay}"
                    IsOn="{x:Bind ViewModel.IncluirPleno, Mode=TwoWay}"
                    AutomationProperties.Name="Incluir pleno al 15 en el análisis" />

                <!-- Acciones -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
                    <Button
                        Content="Cancelar"
                        Click="OnCancelarClick"
                        AutomationProperties.Name="Cancelar y cerrar" />
                    <Button
                        Content="Analizar"
                        Style="{StaticResource AccentButtonStyle}"
                        IsEnabled="{x:Bind ViewModel.PuedeAnalizar, Mode=OneWay}"
                        Command="{x:Bind ViewModel.AnalizarCommand}"
                        AutomationProperties.Name="Analizar el fichero de columnas" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
