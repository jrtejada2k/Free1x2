<Page
    x:Class="Free1X2.WinUI.Views.Ported.StaInterFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                  VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12" Spacing="6">

            <!-- Encabezado: título real del form legacy ("interrupciones 0.1") -->
            <TextBlock Text="Interrupciones" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Text="Tabla de interrupciones de la reducción (5 agregados x 14 partidos)."
                       Style="{StaticResource SecondaryTextBlockStyle}" />

            <!-- Card: opciones (groupBox "mostrar" + nº de columnas) -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock Text="Mostrar" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <StackPanel Spacing="4" MinWidth="200">
                            <TextBlock Text="Valores" Style="{StaticResource CardTitleTextBlockStyle}" />
                            <ComboBox ItemsSource="{x:Bind ViewModel.OpcionesMostrar}"
                                      SelectedIndex="{x:Bind ViewModel.ModoMostrarIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Nº columnas" Style="{StaticResource CardTitleTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.NumColumnasTexto, Mode=OneWay}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Card: matriz 5x14 -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock Text="Detalle por partido" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Fila 0: encabezados de columna (partidos 0..13) -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="0" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="1" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="2" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="3" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="4" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="6" Text="5" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="7" Text="6" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="8" Text="7" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="9" Text="8" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="10" Text="9" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="11" Text="10" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="12" Text="11" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="13" Text="12" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="0" Grid.Column="14" Text="13" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Margin="4,2" />

                        <!-- Encabezados de fila -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="globales" Style="{StaticResource CardTitleTextBlockStyle}" Margin="0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="cant. 1" Style="{StaticResource CardTitleTextBlockStyle}" Margin="0,4" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="cant. X" Style="{StaticResource CardTitleTextBlockStyle}" Margin="0,4" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="cant. 2" Style="{StaticResource CardTitleTextBlockStyle}" Margin="0,4" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="cant. V" Style="{StaticResource CardTitleTextBlockStyle}" Margin="0,4" />

                        <!-- Fila "globales" (rsl[0,*]) -->
                        <TextBlock Grid.Row="1" Grid.Column="1"  Text="{x:Bind ViewModel.Celdas[0][0],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="2"  Text="{x:Bind ViewModel.Celdas[0][1],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="3"  Text="{x:Bind ViewModel.Celdas[0][2],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="4"  Text="{x:Bind ViewModel.Celdas[0][3],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="5"  Text="{x:Bind ViewModel.Celdas[0][4],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="6"  Text="{x:Bind ViewModel.Celdas[0][5],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="7"  Text="{x:Bind ViewModel.Celdas[0][6],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="8"  Text="{x:Bind ViewModel.Celdas[0][7],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="9"  Text="{x:Bind ViewModel.Celdas[0][8],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="10" Text="{x:Bind ViewModel.Celdas[0][9],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="11" Text="{x:Bind ViewModel.Celdas[0][10], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="12" Text="{x:Bind ViewModel.Celdas[0][11], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="13" Text="{x:Bind ViewModel.Celdas[0][12], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="1" Grid.Column="14" Text="{x:Bind ViewModel.Celdas[0][13], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />

                        <!-- Fila "cant. 1" (rsl[1,*]) -->
                        <TextBlock Grid.Row="2" Grid.Column="1"  Text="{x:Bind ViewModel.Celdas[1][0],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="2"  Text="{x:Bind ViewModel.Celdas[1][1],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="3"  Text="{x:Bind ViewModel.Celdas[1][2],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="4"  Text="{x:Bind ViewModel.Celdas[1][3],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="5"  Text="{x:Bind ViewModel.Celdas[1][4],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="6"  Text="{x:Bind ViewModel.Celdas[1][5],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="7"  Text="{x:Bind ViewModel.Celdas[1][6],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="8"  Text="{x:Bind ViewModel.Celdas[1][7],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="9"  Text="{x:Bind ViewModel.Celdas[1][8],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="10" Text="{x:Bind ViewModel.Celdas[1][9],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="11" Text="{x:Bind ViewModel.Celdas[1][10], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="12" Text="{x:Bind ViewModel.Celdas[1][11], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="13" Text="{x:Bind ViewModel.Celdas[1][12], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="2" Grid.Column="14" Text="{x:Bind ViewModel.Celdas[1][13], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />

                        <!-- Fila "cant. X" (rsl[2,*]) -->
                        <TextBlock Grid.Row="3" Grid.Column="1"  Text="{x:Bind ViewModel.Celdas[2][0],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="2"  Text="{x:Bind ViewModel.Celdas[2][1],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="3"  Text="{x:Bind ViewModel.Celdas[2][2],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="4"  Text="{x:Bind ViewModel.Celdas[2][3],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="5"  Text="{x:Bind ViewModel.Celdas[2][4],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="6"  Text="{x:Bind ViewModel.Celdas[2][5],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="7"  Text="{x:Bind ViewModel.Celdas[2][6],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="8"  Text="{x:Bind ViewModel.Celdas[2][7],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="9"  Text="{x:Bind ViewModel.Celdas[2][8],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="10" Text="{x:Bind ViewModel.Celdas[2][9],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="11" Text="{x:Bind ViewModel.Celdas[2][10], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="12" Text="{x:Bind ViewModel.Celdas[2][11], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="13" Text="{x:Bind ViewModel.Celdas[2][12], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="3" Grid.Column="14" Text="{x:Bind ViewModel.Celdas[2][13], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />

                        <!-- Fila "cant. 2" (rsl[3,*]) -->
                        <TextBlock Grid.Row="4" Grid.Column="1"  Text="{x:Bind ViewModel.Celdas[3][0],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="2"  Text="{x:Bind ViewModel.Celdas[3][1],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="3"  Text="{x:Bind ViewModel.Celdas[3][2],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="4"  Text="{x:Bind ViewModel.Celdas[3][3],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="5"  Text="{x:Bind ViewModel.Celdas[3][4],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="6"  Text="{x:Bind ViewModel.Celdas[3][5],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="7"  Text="{x:Bind ViewModel.Celdas[3][6],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="8"  Text="{x:Bind ViewModel.Celdas[3][7],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="9"  Text="{x:Bind ViewModel.Celdas[3][8],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="10" Text="{x:Bind ViewModel.Celdas[3][9],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="11" Text="{x:Bind ViewModel.Celdas[3][10], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="12" Text="{x:Bind ViewModel.Celdas[3][11], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="13" Text="{x:Bind ViewModel.Celdas[3][12], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="4" Grid.Column="14" Text="{x:Bind ViewModel.Celdas[3][13], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />

                        <!-- Fila "cant. V" (rsl[4,*]) -->
                        <TextBlock Grid.Row="5" Grid.Column="1"  Text="{x:Bind ViewModel.Celdas[4][0],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="2"  Text="{x:Bind ViewModel.Celdas[4][1],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="3"  Text="{x:Bind ViewModel.Celdas[4][2],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="4"  Text="{x:Bind ViewModel.Celdas[4][3],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="5"  Text="{x:Bind ViewModel.Celdas[4][4],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="6"  Text="{x:Bind ViewModel.Celdas[4][5],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="7"  Text="{x:Bind ViewModel.Celdas[4][6],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="8"  Text="{x:Bind ViewModel.Celdas[4][7],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="9"  Text="{x:Bind ViewModel.Celdas[4][8],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="10" Text="{x:Bind ViewModel.Celdas[4][9],  Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="11" Text="{x:Bind ViewModel.Celdas[4][10], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="12" Text="{x:Bind ViewModel.Celdas[4][11], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="13" Text="{x:Bind ViewModel.Celdas[4][12], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                        <TextBlock Grid.Row="5" Grid.Column="14" Text="{x:Bind ViewModel.Celdas[4][13], Mode=OneWay}" HorizontalAlignment="Center" Margin="4,2" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
