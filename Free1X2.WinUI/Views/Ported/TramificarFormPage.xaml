<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.TramificarFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="980" HorizontalAlignment="Left">

            <!-- ===== Encabezado (this.Text = "Tramificar") ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Tramificar" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Reparte el universo de columnas (3^14) en tramos según su valoración, usando los datos de premios de la L.A.E. de una jornada, y permite filtrar por posiciones y localizar columnas concretas."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
                <TextBlock Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

            <!-- ===== Definición tramo (GroupBox grDefTramo) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Definición del tramo" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Columna inicial"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="0" Grid.Column="1"
                                   Value="{x:Bind ViewModel.ColumnaInicial, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Columna inicial del rango a tramificar" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Columna final"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="1" Grid.Column="1"
                                   Value="{x:Bind ViewModel.ColumnaFinal, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Columna final del rango a tramificar" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Columnas / tramo"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="2" Grid.Column="1"
                                   Value="{x:Bind ViewModel.ColumnasPorTramo, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Compact"
                                   AutomationProperties.Name="Número de columnas por tramo" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Nº de tramos"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <ComboBox Grid.Row="3" Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.OpcionesNumTramos}"
                                  SelectedItem="{x:Bind ViewModel.NumTramos, Mode=TwoWay}"
                                  AutomationProperties.Name="Número de tramos" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Datos L.A.E. (GroupBox groupBox1) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Datos L.A.E." Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Columna premiada"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                                 CharacterCasing="Upper" MaxLength="14"
                                 Text="{x:Bind ViewModel.ColumnaPremiada, Mode=TwoWay}"
                                 AutomationProperties.Name="Columna premiada (combinación ganadora)" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Temporada"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1" MaxLength="14"
                                 Text="{x:Bind ViewModel.Temporada, Mode=TwoWay}"
                                 AutomationProperties.Name="Temporada (año de inicio)" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Jornada"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="1" Grid.Column="3"
                                   Minimum="1" Maximum="70"
                                   Value="{x:Bind ViewModel.Jornada, Mode=TwoWay}"
                                   SpinButtonPlacementMode="Inline"
                                   AutomationProperties.Name="Jornada" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Recaudación"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" MaxLength="14"
                                 Text="{x:Bind ViewModel.Recaudacion, Mode=TwoWay}"
                                 AutomationProperties.Name="Recaudación de la jornada" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Premios por categoría (GroupBox grPremiosLAE) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Premios" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Importe del premio por categoría de aciertos. El interruptor bloquea esa categoría en el cálculo."
                               Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="14"
                                   VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1" TextAlignment="Right"
                                 Text="{x:Bind ViewModel.Premio14, Mode=TwoWay}"
                                 AutomationProperties.Name="Importe del premio de 14 aciertos" />
                        <ToggleSwitch Grid.Row="0" Grid.Column="2" OffContent="" OnContent="Bloq."
                                      IsOn="{x:Bind ViewModel.Bloqueado14, Mode=TwoWay}"
                                      AutomationProperties.Name="Bloquear categoría de 14 aciertos" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="13"
                                   VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1" TextAlignment="Right"
                                 Text="{x:Bind ViewModel.Premio13, Mode=TwoWay}"
                                 AutomationProperties.Name="Importe del premio de 13 aciertos" />
                        <ToggleSwitch Grid.Row="1" Grid.Column="2" OffContent="" OnContent="Bloq."
                                      IsOn="{x:Bind ViewModel.Bloqueado13, Mode=TwoWay}"
                                      AutomationProperties.Name="Bloquear categoría de 13 aciertos" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="12"
                                   VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1" TextAlignment="Right"
                                 Text="{x:Bind ViewModel.Premio12, Mode=TwoWay}"
                                 AutomationProperties.Name="Importe del premio de 12 aciertos" />
                        <ToggleSwitch Grid.Row="2" Grid.Column="2" OffContent="" OnContent="Bloq."
                                      IsOn="{x:Bind ViewModel.Bloqueado12, Mode=TwoWay}"
                                      AutomationProperties.Name="Bloquear categoría de 12 aciertos" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="11"
                                   VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1" TextAlignment="Right"
                                 Text="{x:Bind ViewModel.Premio11, Mode=TwoWay}"
                                 AutomationProperties.Name="Importe del premio de 11 aciertos" />
                        <ToggleSwitch Grid.Row="3" Grid.Column="2" OffContent="" OnContent="Bloq."
                                      IsOn="{x:Bind ViewModel.Bloqueado11, Mode=TwoWay}"
                                      AutomationProperties.Name="Bloquear categoría de 11 aciertos" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="10"
                                   VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="4" Grid.Column="1" TextAlignment="Right"
                                 Text="{x:Bind ViewModel.Premio10, Mode=TwoWay}"
                                 AutomationProperties.Name="Importe del premio de 10 aciertos" />
                        <ToggleSwitch Grid.Row="4" Grid.Column="2" OffContent="" OnContent="Bloq."
                                      IsOn="{x:Bind ViewModel.Bloqueado10, Mode=TwoWay}"
                                      AutomationProperties.Name="Bloquear categoría de 10 aciertos" />
                    </Grid>

                    <Button Content="Guardar jornada L.A.E."
                            Command="{x:Bind ViewModel.GuardarJornadaLaeCommand}"
                            AutomationProperties.Name="Guardar los datos de premios de la jornada" />
                </StackPanel>
            </Border>

            <!-- ===== Posiciones mínimas y máximas (GroupBox grMinMax) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Posiciones mínimas y máximas" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Rango de posición admitido dentro del tramo para cada categoría de premio."
                               Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="de"
                                   HorizontalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Mínima"
                                   HorizontalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Máxima"
                                   HorizontalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="14"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Min14, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición mínima de 14" />
                        <TextBox Grid.Row="1" Grid.Column="2" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Max14, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición máxima de 14" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Min13, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición mínima de 13" />
                        <TextBox Grid.Row="2" Grid.Column="2" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Max13, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición máxima de 13" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="12"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Min12, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición mínima de 12" />
                        <TextBox Grid.Row="3" Grid.Column="2" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Max12, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición máxima de 12" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="4" Grid.Column="1" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Min11, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición mínima de 11" />
                        <TextBox Grid.Row="4" Grid.Column="2" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Max11, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición máxima de 11" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="10"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Row="5" Grid.Column="1" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Min10, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición mínima de 10" />
                        <TextBox Grid.Row="5" Grid.Column="2" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.Max10, Mode=TwoWay}"
                                 AutomationProperties.Name="Posición máxima de 10" />
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nº columnas filtro"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ColumnasFiltro, Mode=OneWay}"
                                   VerticalAlignment="Center" Style="{StaticResource CardTitleTextBlockStyle}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Filtrar"
                                Command="{x:Bind ViewModel.FiltrarCommand}"
                                AutomationProperties.Name="Aplicar filtro de posiciones" />
                        <Button Content="Grabar filtro"
                                Command="{x:Bind ViewModel.GrabarFiltroCommand}"
                                AutomationProperties.Name="Grabar columnas filtradas" />
                        <Button Content="Leer límites"
                                Command="{x:Bind ViewModel.LeerLimitesCommand}"
                                AutomationProperties.Name="Leer límites de posiciones" />
                        <Button Content="Guardar límites"
                                Command="{x:Bind ViewModel.GuardarLimitesCommand}"
                                AutomationProperties.Name="Guardar límites de posiciones" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Ver columna (GroupBox groupBox2) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Ver columna" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Columna"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 CharacterCasing="Upper" MaxLength="14" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.ColumnaEnPosicion, Mode=TwoWay}"
                                 AutomationProperties.Name="Columna en la posición actual" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Aciertos"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="1" IsReadOnly="True"
                                 Text="{x:Bind ViewModel.Aciertos, Mode=OneWay}"
                                 AutomationProperties.Name="Aciertos de la columna mostrada" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Aciertos a buscar"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{x:Bind ViewModel.OpcionesAciertosABuscar}"
                                  SelectedItem="{x:Bind ViewModel.AciertosABuscar, Mode=TwoWay}"
                                  AutomationProperties.Name="Aciertos a buscar al saltar de columna" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Valoración / LN"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Row="3" Grid.Column="1" IsReadOnly="True"
                                 Text="{x:Bind ViewModel.Probabilidad, Mode=OneWay}"
                                 AutomationProperties.Name="Valoración de la columna mostrada" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Anterior"
                                Command="{x:Bind ViewModel.ColumnaAnteriorCommand}"
                                AutomationProperties.Name="Columna anterior del tramo" />
                        <Button Content="Siguiente"
                                Command="{x:Bind ViewModel.ColumnaSiguienteCommand}"
                                AutomationProperties.Name="Columna siguiente del tramo" />
                        <Button Content="Buscar columna"
                                Command="{x:Bind ViewModel.BuscarColumnaCommand}"
                                AutomationProperties.Name="Buscar columna en el tramo" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Parámetros de valoración ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Valoración" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="LN central"
                                   VerticalAlignment="Center" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBox Grid.Column="1" TextAlignment="Center"
                                 Text="{x:Bind ViewModel.LnCentral, Mode=TwoWay}"
                                 AutomationProperties.Name="LN central" />
                    </Grid>

                    <ToggleSwitch OffContent="No acumular" OnContent="Acumular resultados de jornadas distintas"
                                  IsOn="{x:Bind ViewModel.Acumular, Mode=TwoWay}"
                                  AutomationProperties.Name="Acumular resultados de jornadas distintas" />
                </StackPanel>
            </Border>

            <!-- ===== Resultados (rejilla dgResultados / dgResultadosPrAcum) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Resultados" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Aquí se mostrarán los tramos calculados y su probabilidad acumulada. La rejilla de resultados se portará por separado."
                               Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap" />
                    <!-- TODO: Dominio legacy — rejillas dgResultados (tramos) y dgResultadosPrAcum
                         (probabilidad acumulada) de TramificarForm, alimentadas por la lógica de
                         escrutinio/valoración (MotorCalculo, Escrutinio, ApuestaProbEscrutada). -->
                </StackPanel>
            </Border>

            <!-- ===== Acciones principales ===== -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="Tramificar"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.TramificarCommand}"
                        AutomationProperties.Name="Calcular los tramos" />
                <Button Content="Grabar tramos"
                        Command="{x:Bind ViewModel.GrabarTramosCommand}"
                        AutomationProperties.Name="Grabar los tramos calculados" />
                <Button Content="Cancelar"
                        Command="{x:Bind ViewModel.CancelarCommand}"
                        AutomationProperties.Name="Cancelar" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
