<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.VisorEstadisticasPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado (legacy: Form.Text = "Estadísticas") -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="Estadísticas"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Porcentaje de cumplimiento de cada fichero analizado."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Tarjeta con el listado (legacy: dgEstadisticas DataGridView de solo lectura) -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Cabecera de columnas (legacy DataColumn: Archivo / Cumplimiento) -->
                <Grid Grid.Row="0" Padding="12,0,12,8" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Archivo"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <TextBlock Grid.Column="1" Text="Cumplimiento"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}"
                        HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="%" MinWidth="60"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}"
                        HorizontalAlignment="Center" />
                </Grid>

                <!-- Estado vacío (cuando no hay estadísticas que mostrar) -->
                <TextBlock
                    Grid.Row="1"
                    Text="No hay estadísticas para mostrar."
                    Style="{StaticResource SecondaryTextBlockStyle}"
                    Foreground="{ThemeResource AppTextSecondaryBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.SinDatos, Mode=OneWay}" />

                <!-- Filas de resultados (legacy: dgEstadisticas, FullRowSelect, ReadOnly) -->
                <ListView
                    x:Name="ListaEstadisticas"
                    Grid.Row="1"
                    ItemsSource="{x:Bind ViewModel.Estadisticas, Mode=OneWay}"
                    SelectionMode="Single"
                    AutomationProperties.Name="Listado de estadísticas">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:EstadisticaItem">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Archivo}"
                                    TextTrimming="CharacterEllipsis"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource AppTextBrush}" />
                                <!-- Barra de cumplimiento (mismo valor que el texto %, sólo visual) -->
                                <ProgressBar Grid.Column="1"
                                    Minimum="0" Maximum="100"
                                    Value="{x:Bind CumplimientoValor}"
                                    VerticalAlignment="Center"
                                    Margin="4,0" />
                                <TextBlock Grid.Column="2" Text="{x:Bind Cumplimiento}"
                                    MinWidth="60"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    Foreground="{ThemeResource AppTextBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
