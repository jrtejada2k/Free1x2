<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.PremiadasFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado (legacy: this.Text = "Análisis Premiadas") -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="Análisis Premiadas"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Cuenta cuántas columnas resultarían premiadas (10/11/12/13 aciertos) a partir de un fichero de columnas ganadoras, y permite grabar o analizar las frecuencias obtenidas."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Tarjeta de configuración: fichero, premio a estudiar y cálculo -->
        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}" Margin="0,0,0,16">
            <StackPanel Spacing="16">
                <TextBlock
                    Text="Configuración"
                    Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <!-- Fichero de columnas ganadoras (legacy: bFileIn + lFileIn) -->
                <StackPanel Spacing="6">
                    <TextBlock
                        Text="Fichero de columnas ganadoras"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            IsReadOnly="True"
                            Text="{x:Bind ViewModel.FicheroGanadoras, Mode=OneWay}"
                            AutomationProperties.Name="Fichero de columnas ganadoras seleccionado" />
                        <Button
                            Grid.Column="1"
                            Content="Seleccionar fichero"
                            Command="{x:Bind ViewModel.SeleccionarFicheroCommand}"
                            AutomationProperties.Name="Seleccionar fichero de columnas ganadoras" />
                    </Grid>
                </StackPanel>

                <!-- Premio a estudiar (legacy: groupBox1 con rb13/rb12/rb11/rb10) -->
                <StackPanel Spacing="6">
                    <TextBlock
                        Text="Premios a estudiar"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <ComboBox
                        MinWidth="200"
                        ItemsSource="{x:Bind ViewModel.OpcionesPremio}"
                        SelectedIndex="{x:Bind ViewModel.PremioSeleccionadoIndex, Mode=TwoWay}"
                        AutomationProperties.Name="Categoría de premio a estudiar" />
                </StackPanel>

                <!-- Acción de cálculo + métricas (legacy: bCalcular, lProc, lTime) -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="0"
                        Content="Calcular"
                        Style="{StaticResource AccentButtonStyle}"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.CalcularCommand}"
                        AutomationProperties.Name="Calcular frecuencias de premios" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock
                            Text="Procesadas"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.ProcesadasTexto, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock
                            Text="Tiempo"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.TiempoTexto, Mode=OneWay}"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Foreground="{ThemeResource AppTextBrush}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Tarjeta de resultados: frecuencias y jornadas -->
        <Border Grid.Row="2" Style="{StaticResource AppCardStyle}">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Columna izquierda: Frecuencias (legacy: label1 + lbPremis) -->
                <TextBlock
                    Grid.Row="0" Grid.Column="0"
                    Text="Frecuencias"
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Margin="0,0,0,8" />
                <ListView
                    x:Name="ListaFrecuencias"
                    Grid.Row="1" Grid.Column="0"
                    ItemsSource="{x:Bind ViewModel.Frecuencias, Mode=OneWay}"
                    SelectionMode="Extended"
                    AutomationProperties.Name="Listado de frecuencias de premios">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                Text="{x:Bind}"
                                FontFamily="Consolas"
                                Foreground="{ThemeResource AppTextBrush}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Columna derecha: Jornadas (legacy: label2 + lbSecuencia) -->
                <TextBlock
                    Grid.Row="0" Grid.Column="1"
                    Text="Jornadas"
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Margin="0,0,0,8" />
                <ListView
                    Grid.Row="1" Grid.Column="1"
                    ItemsSource="{x:Bind ViewModel.Jornadas, Mode=OneWay}"
                    SelectionMode="None"
                    AutomationProperties.Name="Jornadas en que aparece la frecuencia seleccionada">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                Text="{x:Bind}"
                                Foreground="{ThemeResource AppTextBrush}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Acciones sobre la frecuencia seleccionada (legacy: bGrabar, bAnaliza) -->
                <StackPanel
                    Grid.Row="2" Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="12"
                    Margin="0,16,0,0">
                    <Button
                        Content="Grabar Selección"
                        Command="{x:Bind ViewModel.GrabarCommand}"
                        AutomationProperties.Name="Grabar a fichero las columnas de la frecuencia seleccionada" />
                    <Button
                        Content="Analiza Selección"
                        Command="{x:Bind ViewModel.AnalizarCommand}"
                        AutomationProperties.Name="Analizar en qué jornadas aparece la frecuencia seleccionada" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
