<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AnalizadorJPMPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="10,7" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock
                    Text="Sumas Pares Naturales (JPM)"
                    Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock
                    Text="Puntúa cada par de signos, clasifica las columnas de un fichero en 36 casillas de suma y analiza los premios de la columna ganadora."
                    Style="{StaticResource SecondaryTextBlockStyle}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!-- Cuerpo: dos columnas -->
            <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Valores a usar (max. 5) -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="Valores a usar (máx. 5)"
                            Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBlock
                            Text="Puntos por cada par de signos consecutivos."
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            TextWrapping="Wrap" />

                        <Grid ColumnSpacing="10" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <NumberBox Grid.Row="0" Grid.Column="0" Header="11"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Valor11, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par 1-1" />
                            <NumberBox Grid.Row="0" Grid.Column="1" Header="1X"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Valor1X, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par 1-X" />
                            <NumberBox Grid.Row="0" Grid.Column="2" Header="12"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Valor12, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par 1-2" />

                            <NumberBox Grid.Row="1" Grid.Column="0" Header="X1"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.ValorX1, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par X-1" />
                            <NumberBox Grid.Row="1" Grid.Column="1" Header="XX"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.ValorXX, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par X-X" />
                            <NumberBox Grid.Row="1" Grid.Column="2" Header="X2"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.ValorX2, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par X-2" />

                            <NumberBox Grid.Row="2" Grid.Column="0" Header="21"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Valor21, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par 2-1" />
                            <NumberBox Grid.Row="2" Grid.Column="1" Header="2X"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Valor2X, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par 2-X" />
                            <NumberBox Grid.Row="2" Grid.Column="2" Header="22"
                                Minimum="0" Maximum="5" SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Valor22, Mode=TwoWay}"
                                AutomationProperties.Name="Valor para el par 2-2" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Proceso (Iniciar / Grabar / estado) -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="Proceso de columnas"
                            Style="{StaticResource CardTitleTextBlockStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Button Content="Iniciar"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.IniciarCommand}"
                                AutomationProperties.Name="Cargar fichero y clasificar columnas" />
                            <Button Content="Grabar"
                                Command="{x:Bind ViewModel.GrabarCommand}"
                                AutomationProperties.Name="Grabar columnas seleccionadas" />
                            <Button Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar el proceso en curso" />
                        </StackPanel>

                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Fichero entrada:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                Text="{x:Bind ViewModel.FicheroEntrada, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fichero salida:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                Text="{x:Bind ViewModel.FicheroSalida, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Total columnas:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                Text="{x:Bind ViewModel.TotalColumnasTexto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Tiempo:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                Text="{x:Bind ViewModel.TiempoTexto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Casillas de suma (0..35) -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="Casillas de suma (0..35)"
                            Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBlock
                            Text="Marca las casillas a grabar o sumar. El conteo se rellena tras iniciar."
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            TextWrapping="Wrap" />

                        <ListView
                            ItemsSource="{x:Bind ViewModel.Casillas}"
                            SelectionMode="None"
                            Height="320"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="1"
                            Background="{ThemeResource AppSurfaceAltBrush}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:CasillaSumaViewModel">
                                    <Grid ColumnSpacing="12" Padding="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                            MinWidth="0"
                                            IsChecked="{x:Bind Seleccionada, Mode=TwoWay}"
                                            AutomationProperties.Name="Seleccionar casilla" />
                                        <TextBlock Grid.Column="1"
                                            Text="{x:Bind IndiceTexto}"
                                            VerticalAlignment="Center"
                                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Grid.Column="2"
                                            Text="{x:Bind ConteoTexto, Mode=OneWay}"
                                            VerticalAlignment="Center"
                                            Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Sumar"
                                Command="{x:Bind ViewModel.SumarCommand}"
                                AutomationProperties.Name="Sumar conteos seleccionados" />
                            <TextBlock Grid.Column="1" Text="Suma:"
                                VerticalAlignment="Center" Margin="8,0,0,0"
                                Style="{StaticResource SecondaryTextBlockStyle}" />
                            <TextBlock Grid.Column="2"
                                Text="{x:Bind ViewModel.SumaSeleccionTexto, Mode=OneWay}"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Análisis de resultados + premios -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="5">
                        <TextBlock
                            Text="Análisis de resultados"
                            Style="{StaticResource CardTitleTextBlockStyle}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Cargar ganadoras"
                                Command="{x:Bind ViewModel.CargarGanadorasCommand}"
                                AutomationProperties.Name="Cargar fichero de columnas ganadoras" />
                            <Button Content="-"
                                Command="{x:Bind ViewModel.AnteriorGanadoraCommand}"
                                AutomationProperties.Name="Columna ganadora anterior" />
                            <Button Content="+"
                                Command="{x:Bind ViewModel.SiguienteGanadoraCommand}"
                                AutomationProperties.Name="Columna ganadora siguiente" />
                        </StackPanel>

                        <TextBox Header="Columna ganadora"
                            Text="{x:Bind ViewModel.ColumnaGanadora, Mode=TwoWay}"
                            AutomationProperties.Name="Columna ganadora a analizar" />

                        <Grid ColumnSpacing="12" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Fichero ganadoras:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                Text="{x:Bind ViewModel.FicheroGanadorasTexto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Índice:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                Text="{x:Bind ViewModel.IndiceGanadoraTexto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Puntuación:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                Text="{x:Bind ViewModel.PuntuacionGanadoraTexto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />
                        </Grid>

                        <Button Content="Analizar"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.AnalizarCommand}"
                            AutomationProperties.Name="Analizar premios de la columna ganadora" />

                        <TextBlock
                            Text="Premios"
                            Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <Grid ColumnSpacing="12" RowSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="14 aciertos:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                Text="{x:Bind ViewModel.Premios14Texto, Mode=OneWay}"
                                Foreground="{ThemeResource AppSuccessBrush}"
                                Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="13 aciertos:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                Text="{x:Bind ViewModel.Premios13Texto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="12 aciertos:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                Text="{x:Bind ViewModel.Premios12Texto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="11 aciertos:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3" Grid.Column="1"
                                Text="{x:Bind ViewModel.Premios11Texto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="10 aciertos:"
                                Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" />
                            <TextBlock Grid.Row="4" Grid.Column="1"
                                Text="{x:Bind ViewModel.Premios10Texto, Mode=OneWay}"
                                Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
