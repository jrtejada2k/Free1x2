<Page
    x:Class="Free1X2.WinUI.Views.Ported.GenerarCPsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer Padding="10,7">
        <StackPanel Spacing="6" MaxWidth="900">

            <!-- Encabezado -->
            <TextBlock
                Text="Generador de Columnas Probables"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Introduce la valoración 1 / X / 2 (en porcentaje) de cada partido y genera las columnas probables para una jornada."
                Style="{StaticResource SecondaryTextBlockStyle}" />

            <!-- Valoración por partido -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Valoración"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <!-- Cabecera de columnas -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Partido" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="1" Text="1" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="2" Text="X" Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Column="3" Text="2" Style="{StaticResource CaptionTextBlockStyle}" />
                    </Grid>

                    <ListView
                        ItemsSource="{x:Bind ViewModel.Valoraciones}"
                        SelectionMode="None"
                        IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0,2" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ValoracionPartidoItem">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind NumeroPartidoTexto}"
                                        Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <NumberBox
                                        Grid.Column="1"
                                        Margin="4,0"
                                        Minimum="0"
                                        SpinButtonPlacementMode="Hidden"
                                        Value="{x:Bind Valor1, Mode=TwoWay}" />
                                    <NumberBox
                                        Grid.Column="2"
                                        Margin="4,0"
                                        Minimum="0"
                                        SpinButtonPlacementMode="Hidden"
                                        Value="{x:Bind ValorX, Mode=TwoWay}" />
                                    <NumberBox
                                        Grid.Column="3"
                                        Margin="4,0"
                                        Minimum="0"
                                        SpinButtonPlacementMode="Hidden"
                                        Value="{x:Bind Valor2, Mode=TwoWay}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Content="Importar %"
                        Command="{x:Bind ViewModel.ImportarPorcentajesCommand}" />
                </StackPanel>
            </Border>

            <!-- Jornada y generación -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Generar columnas"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <NumberBox
                        Header="Jornada"
                        Minimum="0"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind ViewModel.Jornada, Mode=TwoWay}" />

                    <Button
                        Content="Generar (OK)"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.GenerarCommand}" />

                    <TextBlock
                        Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}" />
                </StackPanel>
            </Border>

            <!-- Herramientas adicionales -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Text="Herramientas"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <Button
                        Content="Configurar columnas"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ConfigurarColumnasCommand}" />
                    <Button
                        Content="Separador de porcentajes"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.SeparadorPorcentajesCommand}" />
                    <Button
                        Content="CPs por diferencias"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CpsPorDiferenciasCommand}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
