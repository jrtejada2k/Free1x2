<Page
    x:Class="Free1X2.WinUI.Views.Ported.VisorAnalisisColumnasFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ported="using:Free1X2.WinUI.Views.Ported"
    xmlns:analisis="using:Free1X2.WinUI.Controls.Analisis"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Análisis" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Visor de análisis de columnas por secciones"
                Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <!-- Contenido: lista de secciones + detalle -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Lista de secciones de análisis (legacy: pestañas del TabControl) -->
            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Secciones"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Secciones}"
                        SelectedItem="{x:Bind ViewModel.SeccionSeleccionada, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="ported:SeccionAnalisisItem">
                                <Grid Padding="0,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind Titulo, Mode=OneWay}"
                                        TextWrapping="Wrap"
                                        Foreground="{ThemeResource AppTextBrush}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind EstadoMarcador, Mode=OneWay}"
                                        Foreground="{ThemeResource AppSuccessBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Grid.Row="2"
                        Content="Refrescar"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.RefrescarCommand}" />
                </Grid>
            </Border>

            <!-- Detalle de la sección seleccionada -->
            <Border Grid.Column="1" Style="{StaticResource AppCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="{x:Bind ViewModel.DetalleTitulo, Mode=OneWay}"
                        Style="{StaticResource CardTitleTextBlockStyle}" />

                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind ViewModel.DetalleTexto, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        TextWrapping="Wrap" />

                    <!-- Presentación rica del dominio (réplica de los CtrlAnalisis* del WinForms):
                         matrices con cabecera de índices + filas de conceptos, o columnas de valoración. -->
                    <ScrollViewer
                        Grid.Row="2"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="16">

                            <!-- Presentador de matrices (VX2/Seguidos/Contactos/Pesos/Distancias/
                                 Interrupciones/Dibujos/Control*/Simetrías/Diferencias/CPs/Formatos) -->
                            <ItemsControl
                                ItemsSource="{x:Bind ViewModel.BloquesDetalle, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.VisibilidadMatrices, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="ported:BloqueMatrizAnalisis">
                                        <StackPanel Spacing="6" Margin="0,0,0,8">
                                            <TextBlock
                                                Text="{x:Bind Titulo}"
                                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                                Foreground="{ThemeResource AppTextBrush}"
                                                Visibility="{x:Bind ported:VisorAnalisisColumnasFrmPage.VisibilidadTexto(Titulo)}" />
                                            <analisis:MatrizAnalisisView Matriz="{x:Bind Matriz}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Presentador de valoración: 4 columnas (Global/Unos/Equis/Doses) -->
                            <ItemsControl
                                ItemsSource="{x:Bind ViewModel.ColumnasValoracionDetalle, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.VisibilidadValoracion, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="16" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="analisis:ColumnaValoracion">
                                        <Border
                                            MinWidth="160"
                                            Background="{ThemeResource AppSurfaceBrush}"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="8"
                                            VerticalAlignment="Top">
                                            <StackPanel Spacing="6">
                                                <TextBlock
                                                    Text="{x:Bind Titulo}"
                                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                                    Foreground="{ThemeResource AppTextBrush}" />
                                                <!-- Cabecera Valor / Columnas -->
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Valor"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="1" Text="Columnas"
                                                        Style="{StaticResource CaptionTextBlockStyle}"
                                                        Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{x:Bind Entradas}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="analisis:EntradaValorAnalisis">
                                                            <Grid ColumnSpacing="8" Padding="0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0"
                                                                    Background="{ThemeResource AppSurfaceAltBrush}"
                                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                                    BorderThickness="1" CornerRadius="2" Padding="2">
                                                                    <TextBlock Text="{x:Bind Clave}"
                                                                        HorizontalAlignment="Center"
                                                                        FontFamily="Consolas"
                                                                        Foreground="{ThemeResource AppTextBrush}" />
                                                                </Border>
                                                                <Border Grid.Column="1"
                                                                    Background="{ThemeResource AppSurfaceBrush}"
                                                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                                                    BorderThickness="1" CornerRadius="2" Padding="2">
                                                                    <TextBlock Text="{x:Bind Columnas}"
                                                                        HorizontalAlignment="Center"
                                                                        FontFamily="Consolas"
                                                                        Foreground="{ThemeResource AppTextBrush}" />
                                                                </Border>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
