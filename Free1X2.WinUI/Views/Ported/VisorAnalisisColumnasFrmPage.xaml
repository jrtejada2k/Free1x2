<Page
    x:Class="Free1X2.WinUI.Views.Ported.VisorAnalisisColumnasFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ported="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Análisis" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Visor de análisis de columnas por secciones"
                Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <!-- Contenido: lista de secciones + detalle -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Lista de secciones de análisis (legacy: pestañas del TabControl) -->
            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Secciones"
                        Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <ListView
                        Grid.Row="1"
                        ItemsSource="{x:Bind ViewModel.Secciones}"
                        SelectedItem="{x:Bind ViewModel.SeccionSeleccionada, Mode=TwoWay}"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="ported:SeccionAnalisisItem">
                                <Grid Padding="0,6" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind Titulo, Mode=OneWay}"
                                        TextWrapping="Wrap"
                                        Foreground="{ThemeResource AppTextBrush}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind EstadoMarcador, Mode=OneWay}"
                                        Foreground="{ThemeResource AppSuccessBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Grid.Row="2"
                        Content="Refrescar"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.RefrescarCommand}" />
                </Grid>
            </Border>

            <!-- Detalle de la sección seleccionada -->
            <Border Grid.Column="1" Style="{StaticResource AppCardStyle}">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="{x:Bind ViewModel.DetalleTitulo, Mode=OneWay}"
                        Style="{StaticResource CardTitleTextBlockStyle}" />

                    <TextBlock
                        Grid.Row="1"
                        Text="{x:Bind ViewModel.DetalleTexto, Mode=OneWay}"
                        Style="{StaticResource SecondaryTextBlockStyle}"
                        TextWrapping="Wrap" />

                    <!-- Datos numéricos de la sección (vuelco de las matrices/figuras del dominio).
                         Los UserControls de análisis del WinForms (CtrlAnalisis*) no están portados;
                         se muestra aquí la información subyacente en una rejilla. -->
                    <Border
                        Grid.Row="2"
                        Background="{ThemeResource AppSurfaceAltBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        MinHeight="280">
                        <ListView
                            ItemsSource="{x:Bind ViewModel.FilasDetalle, Mode=OneWay}"
                            SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="ported:FilaAnalisis">
                                    <Grid Padding="0,4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind Etiqueta}"
                                            Foreground="{ThemeResource AppTextBrush}"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind Valores}"
                                            FontFamily="Consolas"
                                            Foreground="{ThemeResource AppTextSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <Button
                        Grid.Row="3"
                        Content="Abrir sección"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.AbrirSeccionCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
