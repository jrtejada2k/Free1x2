<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.DialogoGrabarBancoPruebasFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="12,8" Spacing="8" MaxWidth="720" HorizontalAlignment="Left">

            <!-- ===== Encabezado (Text del WinForms: "Grabar apuestas") ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Grabar apuestas"
                           Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Exporta a un archivo las apuestas del Banco de Pruebas. Indica el rango de filas a grabar y el número máximo de apuestas."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Rango de apuestas ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Rango de apuestas" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- label1: "Fila de la apuesta inicial" + txColumnaInicial -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Fila de la apuesta inicial"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="0" Grid.Column="1"
                                   Value="{x:Bind ViewModel.FilaInicial, Mode=TwoWay}"
                                   Minimum="0"
                                   SpinButtonPlacementMode="Compact" MinWidth="140"
                                   HorizontalAlignment="Left"
                                   AutomationProperties.Name="Fila de la apuesta inicial" />

                        <!-- label2: "Fila de la apuesta final" + txColumnaFinal -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Fila de la apuesta final"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="1" Grid.Column="1"
                                   Value="{x:Bind ViewModel.FilaFinal, Mode=TwoWay}"
                                   Minimum="0"
                                   SpinButtonPlacementMode="Compact" MinWidth="140"
                                   HorizontalAlignment="Left"
                                   AutomationProperties.Name="Fila de la apuesta final" />

                        <!-- label3: "Nº máximo de apuestas" + txNumColumns -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Nº máximo de apuestas"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="2" Grid.Column="1"
                                   Value="{x:Bind ViewModel.NumMaxColumnas, Mode=TwoWay}"
                                   Minimum="0"
                                   SpinButtonPlacementMode="Compact" MinWidth="140"
                                   HorizontalAlignment="Left"
                                   AutomationProperties.Name="Número máximo de apuestas" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Opciones ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock Text="Opciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <!-- chkSoloSeleccionadas: "sólo si estan seleccionadas" (activado por defecto) -->
                    <ToggleSwitch Header="Grabar solo si están seleccionadas"
                                  IsOn="{x:Bind ViewModel.SoloSeleccionadas, Mode=TwoWay}"
                                  AutomationProperties.Name="Grabar solo las apuestas seleccionadas"
                                  OnContent="Sí" OffContent="No" />
                </StackPanel>
            </Border>

            <!-- ===== Acciones (btGrabar "Aceptar" / btCancelar "Cancelar") + estado ===== -->
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <Button Content="Aceptar"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.GrabarCommand}"
                        AutomationProperties.Name="Aceptar y grabar las apuestas" />
                <Button Content="Cancelar"
                        Command="{x:Bind ViewModel.CancelarCommand}"
                        AutomationProperties.Name="Cancelar la grabación" />
                <TextBlock Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
