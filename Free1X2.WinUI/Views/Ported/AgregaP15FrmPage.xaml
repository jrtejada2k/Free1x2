<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AgregaP15FrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="820" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Añade P15 (Indeciso)"
                           Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Genera el Pleno al 15 (P15) sobre un archivo de columnas existente y lo guarda en un archivo de salida. Elige uno de los cuatro modos."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Archivos ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Archivos" Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Grid.Column="0"
                                Content="Fichero entrada"
                                Click="OnSeleccionarEntrada"
                                AutomationProperties.Name="Seleccionar fichero de entrada"
                                MinWidth="150" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind ViewModel.ArchivoEntrada, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis" />

                        <Button Grid.Row="1" Grid.Column="0"
                                Content="Fichero salida"
                                Click="OnSeleccionarSalida"
                                AutomationProperties.Name="Seleccionar fichero de salida"
                                MinWidth="150" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{x:Bind ViewModel.ArchivoSalida, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Modo 1: P15 fijo ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <ToggleSwitch Header="Partido 15 fijo a un signo"
                                  IsOn="{x:Bind ViewModel.ModoFijo, Mode=TwoWay}"
                                  AutomationProperties.Name="Activar modo Partido 15 fijo"
                                  OnContent="Activo" OffContent="Inactivo" />
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Partido 15 ="
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <ComboBox MinWidth="80"
                                  IsEnabled="{x:Bind ViewModel.ModoFijo, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.Signos}"
                                  SelectedItem="{x:Bind ViewModel.SignoFijo, Mode=TwoWay}"
                                  AutomationProperties.Name="Signo fijo del Partido 15" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Modo 2: Condicional ===== -->
            <!-- NOTA: IsEnabled enlazado con x:Bind se aplica a cada control hijo (NumberBox/ComboBox),
                 no al Grid contenedor. Un x:Bind a IsEnabled sobre un Panel (Grid) hace fallar al
                 XamlCompiler de Windows App SDK 1.6 con un crash opaco (MarkupCompilePass1). -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <ToggleSwitch Header="P15 condicional según otro partido"
                                  IsOn="{x:Bind ViewModel.ModoCondicional, Mode=TwoWay}"
                                  AutomationProperties.Name="Activar modo P15 condicional"
                                  OnContent="Activo" OffContent="Inactivo" />
                    <Grid ColumnSpacing="10" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Si partido"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Grid.Row="0" Grid.Column="1"
                                   Value="{x:Bind ViewModel.PartidoCondicion, Mode=TwoWay}"
                                   IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                   Minimum="1" Maximum="14"
                                   SpinButtonPlacementMode="Compact" MinWidth="120"
                                   AutomationProperties.Name="Número de partido de la condición" />
                        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="10"
                                    VerticalAlignment="Center">
                            <TextBlock Text="=" VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextBlockStyle}" />
                            <ComboBox MinWidth="70"
                                      IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.Signos}"
                                      SelectedItem="{x:Bind ViewModel.SignoCondicion, Mode=TwoWay}"
                                      AutomationProperties.Name="Signo de la condición" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                    Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock Text="entonces P15 =" VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextBlockStyle}" />
                            <ComboBox MinWidth="70"
                                      IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.Signos}"
                                      SelectedItem="{x:Bind ViewModel.SignoSi, Mode=TwoWay}"
                                      AutomationProperties.Name="Signo del P15 si se cumple la condición" />
                            <TextBlock Text="; si no P15 =" VerticalAlignment="Center"
                                       Style="{StaticResource SecondaryTextBlockStyle}" />
                            <ComboBox MinWidth="70"
                                      IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                      ItemsSource="{x:Bind ViewModel.Signos}"
                                      SelectedItem="{x:Bind ViewModel.SignoNo, Mode=TwoWay}"
                                      AutomationProperties.Name="Signo del P15 si no se cumple la condición" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Modo 3: Eliminar partido 15 / repetidas ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <ToggleSwitch Header="Elimina partido 15 (quita el P15 y descarta columnas repetidas)"
                                  IsOn="{x:Bind ViewModel.ModoEliminarRepetidas, Mode=TwoWay}"
                                  AutomationProperties.Name="Activar modo eliminar partido 15 y repetidas"
                                  OnContent="Activo" OffContent="Inactivo" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="Nº columnas repetidas:" VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.ColumnasRepetidasTexto, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Modo 4: Copiar resultado de otro partido ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="12">
                    <ToggleSwitch Header="P15 = resultado de otro partido"
                                  IsOn="{x:Bind ViewModel.ModoCopiarPartido, Mode=TwoWay}"
                                  AutomationProperties.Name="Activar modo copiar resultado de otro partido"
                                  OnContent="Activo" OffContent="Inactivo" />
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="Resultado del P15 igual que el del partido"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Value="{x:Bind ViewModel.PartidoCopia, Mode=TwoWay}"
                                   IsEnabled="{x:Bind ViewModel.ModoCopiarPartido, Mode=OneWay}"
                                   Minimum="1" Maximum="14"
                                   SpinButtonPlacementMode="Compact" MinWidth="120"
                                   AutomationProperties.Name="Número de partido a copiar" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== Acción + estado ===== -->
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <Button Content="Calcular"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.CalcularCommand}"
                        AutomationProperties.Name="Calcular y generar el archivo de salida" />
                <TextBlock Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
