<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AgregaP15FrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="12,8" Spacing="8" MaxWidth="560" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="4">
                <TextBlock Text="Añade P15 (Indeciso)"
                           Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Genera el Pleno al 15 (P15) sobre un archivo de columnas existente y lo guarda en un archivo de salida. Elige uno de los cuatro modos."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ===== Una sola tarjeta compacta: 6 filas (una por concepto),
                 reflejando el WinForms original (ClientSize 400x310). ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <Grid ColumnSpacing="8" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <!-- Col 0: checkBox / botón de fila -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Col 1: contenido de la fila (etiqueta + editores en línea) -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Fila 1: Fichero entrada (btnFileIn + label1) -->
                    <Button Grid.Row="0" Grid.Column="0"
                            Content="Fichero entrada"
                            Click="OnSeleccionarEntrada"
                            AutomationProperties.Name="Seleccionar fichero de entrada"
                            MinWidth="140"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{x:Bind ViewModel.ArchivoEntrada, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextTrimming="CharacterEllipsis" />

                    <!-- Fila 2: Fichero salida (btnFileOut + label2) -->
                    <Button Grid.Row="1" Grid.Column="0"
                            Content="Fichero salida"
                            Click="OnSeleccionarSalida"
                            AutomationProperties.Name="Seleccionar fichero de salida"
                            MinWidth="140"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{x:Bind ViewModel.ArchivoSalida, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextTrimming="CharacterEllipsis" />

                    <!-- Fila 3 (Modo 1): checkBox1 "Partido 15 fijo a" + signo (textBox1 -> ComboBox) -->
                    <CheckBox Grid.Row="2" Grid.Column="0"
                              Content="Partido 15 fijo a"
                              IsChecked="{x:Bind ViewModel.ModoFijo, Mode=TwoWay}"
                              MinWidth="140"
                              AutomationProperties.Name="Activar modo Partido 15 fijo" />
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              MinWidth="70" HorizontalAlignment="Left" VerticalAlignment="Center"
                              IsEnabled="{x:Bind ViewModel.ModoFijo, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.Signos}"
                              SelectedItem="{x:Bind ViewModel.SignoFijo, Mode=TwoWay}"
                              AutomationProperties.Name="Signo fijo del Partido 15" />

                    <!-- Fila 4 (Modo 3): checkBox3 "Elimina partido 15" + "Nº Columnas Repetidas:" + recuento -->
                    <CheckBox Grid.Row="3" Grid.Column="0"
                              Content="Elimina partido 15"
                              IsChecked="{x:Bind ViewModel.ModoEliminarRepetidas, Mode=TwoWay}"
                              MinWidth="140"
                              AutomationProperties.Name="Activar modo eliminar partido 15 y repetidas" />
                    <StackPanel Grid.Row="3" Grid.Column="1"
                                Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Nº Columnas Repetidas:" VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.ColumnasRepetidasTexto, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                    </StackPanel>

                    <!-- Fila 5 (Modo 2): checkBox2 + condición en una sola fila horizontal
                         Si partido [N] = [signo] entonces P15 = [signo] ; si no P15 = [signo] -->
                    <CheckBox Grid.Row="4" Grid.Column="0"
                              IsChecked="{x:Bind ViewModel.ModoCondicional, Mode=TwoWay}"
                              MinWidth="32"
                              AutomationProperties.Name="Activar modo P15 condicional" />
                    <StackPanel Grid.Row="4" Grid.Column="1"
                                Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Si partido" VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Value="{x:Bind ViewModel.PartidoCondicion, Mode=TwoWay}"
                                   IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                   Minimum="1" Maximum="14"
                                   SpinButtonPlacementMode="Compact" MinWidth="96"
                                   AutomationProperties.Name="Número de partido de la condición" />
                        <TextBlock Text="=" VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <ComboBox MinWidth="60"
                                  IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.Signos}"
                                  SelectedItem="{x:Bind ViewModel.SignoCondicion, Mode=TwoWay}"
                                  AutomationProperties.Name="Signo de la condición" />
                        <TextBlock Text="entonces P15 =" VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <ComboBox MinWidth="60"
                                  IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.Signos}"
                                  SelectedItem="{x:Bind ViewModel.SignoSi, Mode=TwoWay}"
                                  AutomationProperties.Name="Signo del P15 si se cumple la condición" />
                        <TextBlock Text="; si no P15 =" VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <ComboBox MinWidth="60"
                                  IsEnabled="{x:Bind ViewModel.ModoCondicional, Mode=OneWay}"
                                  ItemsSource="{x:Bind ViewModel.Signos}"
                                  SelectedItem="{x:Bind ViewModel.SignoNo, Mode=TwoWay}"
                                  AutomationProperties.Name="Signo del P15 si no se cumple la condición" />
                    </StackPanel>

                    <!-- Fila 6 (Modo 4): checkBox4 + "Resultado partido 15 igual que...partido" + N (textBox6) -->
                    <CheckBox Grid.Row="5" Grid.Column="0"
                              IsChecked="{x:Bind ViewModel.ModoCopiarPartido, Mode=TwoWay}"
                              MinWidth="32"
                              AutomationProperties.Name="Activar modo copiar resultado de otro partido" />
                    <StackPanel Grid.Row="5" Grid.Column="1"
                                Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="Resultado partido 15 igual que resultado del partido"
                                   VerticalAlignment="Center" TextWrapping="Wrap"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                        <NumberBox Value="{x:Bind ViewModel.PartidoCopia, Mode=TwoWay}"
                                   IsEnabled="{x:Bind ViewModel.ModoCopiarPartido, Mode=OneWay}"
                                   Minimum="1" Maximum="14"
                                   SpinButtonPlacementMode="Compact" MinWidth="96"
                                   AutomationProperties.Name="Número de partido a copiar" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== Acción + estado (button1 "Calcular" + label4) ===== -->
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Calcular"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.CalcularCommand}"
                        AutomationProperties.Name="Calcular y generar el archivo de salida" />
                <TextBlock Text="{x:Bind ViewModel.Estado, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
