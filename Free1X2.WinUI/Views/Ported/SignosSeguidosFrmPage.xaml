<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.SignosSeguidosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Padding="32" Spacing="24" MaxWidth="820" HorizontalAlignment="Left">

            <!-- ===== Encabezado ===== -->
            <StackPanel Spacing="6">
                <TextBlock Text="Signos Seguidos" Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Especifica la cantidad de Variantes seguidas, de signos 1, X y 2 seguidos por combinación."
                           Style="{StaticResource SecondaryTextBlockStyle}" />
            </StackPanel>

            <!-- ===== Cantidades admitidas por tipo de signo seguido ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Cantidades admitidas (0–15)" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Introduce las cantidades permitidas para cada concepto. Separa varios valores con comas o espacios."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <!-- Var -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Var"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.Variantes, Mode=TwoWay}"
                                 AutomationProperties.Name="Cantidades admitidas de variantes seguidas" />
                    </Grid>

                    <!-- 1 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="1"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.Unos, Mode=TwoWay}"
                                 AutomationProperties.Name="Cantidades admitidas de signos 1 seguidos" />
                    </Grid>

                    <!-- X -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.Equis, Mode=TwoWay}"
                                 AutomationProperties.Name="Cantidades admitidas de signos X seguidos" />
                    </Grid>

                    <!-- 2 -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="2"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CardTitleTextBlockStyle}" />
                        <TextBox Grid.Column="1"
                                 PlaceholderText="p. ej. 0 1 2"
                                 Text="{x:Bind ViewModel.Doses, Mode=TwoWay}"
                                 AutomationProperties.Name="Cantidades admitidas de signos 2 seguidos" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Figuras por tipo de signo (btnFigurasV/1/X/2 del form legacy) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Figuras" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Text="Define las figuras asociadas a cada concepto. Cuando un concepto tiene figuras definidas se muestra como activo."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               TextWrapping="Wrap" />

                    <!-- Figuras Variantes -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                Content="Figuras Variantes"
                                Command="{x:Bind ViewModel.FigurasVariantesCommand}"
                                AutomationProperties.Name="Definir figuras de variantes" />
                        <TextBlock Grid.Column="1" Text="Activas"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AppSuccessBrush}"
                                   Visibility="{x:Bind ViewModel.FigurasVariantesVisibility, Mode=OneWay}"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                    </Grid>

                    <!-- Figuras Unos -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                Content="Figuras Unos"
                                Command="{x:Bind ViewModel.FigurasUnosCommand}"
                                AutomationProperties.Name="Definir figuras de signos 1" />
                        <TextBlock Grid.Column="1" Text="Activas"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AppSuccessBrush}"
                                   Visibility="{x:Bind ViewModel.FigurasUnosVisibility, Mode=OneWay}"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                    </Grid>

                    <!-- Figuras Equis -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                Content="Figuras Equis"
                                Command="{x:Bind ViewModel.FigurasEquisCommand}"
                                AutomationProperties.Name="Definir figuras de signos X" />
                        <TextBlock Grid.Column="1" Text="Activas"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AppSuccessBrush}"
                                   Visibility="{x:Bind ViewModel.FigurasEquisVisibility, Mode=OneWay}"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                    </Grid>

                    <!-- Figuras Doses -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" HorizontalAlignment="Stretch"
                                Content="Figuras Doses"
                                Command="{x:Bind ViewModel.FigurasDosesCommand}"
                                AutomationProperties.Name="Definir figuras de signos 2" />
                        <TextBlock Grid.Column="1" Text="Activas"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource AppSuccessBrush}"
                                   Visibility="{x:Bind ViewModel.FigurasDosesVisibility, Mode=OneWay}"
                                   Style="{StaticResource SecondaryTextBlockStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Acciones (menuCondiciones del form legacy) ===== -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Acciones" Style="{StaticResource CardTitleTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Aceptar"
                                Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.AceptarCommand}"
                                AutomationProperties.Name="Aceptar y aplicar el filtro de signos seguidos" />
                        <Button Content="Estadísticas"
                                Command="{x:Bind ViewModel.EstadisticasCommand}"
                                AutomationProperties.Name="Ver estadísticas del filtro" />
                        <Button Content="Guardar"
                                Command="{x:Bind ViewModel.GuardarCommand}"
                                AutomationProperties.Name="Guardar la condición en un archivo" />
                        <Button Content="Abrir"
                                Command="{x:Bind ViewModel.AbrirCommand}"
                                AutomationProperties.Name="Abrir una condición desde un archivo" />
                        <Button Content="Copiar"
                                Command="{x:Bind ViewModel.CopiarCommand}"
                                AutomationProperties.Name="Copiar la condición al portapapeles temporal" />
                        <Button Content="Pegar"
                                Command="{x:Bind ViewModel.PegarCommand}"
                                AutomationProperties.Name="Pegar la condición desde el portapapeles temporal" />
                        <Button Content="Borrar"
                                Command="{x:Bind ViewModel.BorrarCommand}"
                                AutomationProperties.Name="Borrar todos los valores" />
                        <Button Content="Cancelar"
                                Command="{x:Bind ViewModel.CancelarCommand}"
                                AutomationProperties.Name="Cancelar y cerrar sin aplicar" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
