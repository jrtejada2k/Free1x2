<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.DescargaBoletoFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="10,7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,10">
            <TextBlock
                Text="Descarga de boleto"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Actualiza la jornada de la semana online para rellenar el boleto con los equipos reales."
                Style="{StaticResource SecondaryTextBlockStyle}"
                Foreground="{ThemeResource AppTextSecondaryBrush}" />
        </StackPanel>

        <!-- Tarjeta de parámetros -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}"
            VerticalAlignment="Top"
            MaxWidth="420"
            HorizontalAlignment="Left">
            <StackPanel Spacing="6">

                <!-- Selector de país (España / México) — único control nuevo (diseño aprobado) -->
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="País"
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Foreground="{ThemeResource AppTextBrush}" />
                    <ComboBox
                        Grid.Column="1"
                        MinWidth="140"
                        ItemsSource="{x:Bind ViewModel.Paises}"
                        SelectedItem="{x:Bind ViewModel.PaisSeleccionado, Mode=TwoWay}"
                        AutomationProperties.Name="País de la jornada a descargar" />
                </Grid>

                <!-- Acciones -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="5"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
                    <Button
                        x:Name="BtnDescargar"
                        Content="Actualizar jornada"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnDescargarClick"
                        AutomationProperties.Name="Descargar la jornada del país seleccionado" />
                </StackPanel>

                <!-- Mensaje de estado / resumen (legacy: lblMensaje) -->
                <TextBlock
                    Text="{x:Bind ViewModel.Mensaje, Mode=OneWay}"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Style="{StaticResource SecondaryTextBlockStyle}"
                    Foreground="{ThemeResource AppTextSecondaryBrush}" />

            </StackPanel>
        </Border>
    </Grid>
</Page>
