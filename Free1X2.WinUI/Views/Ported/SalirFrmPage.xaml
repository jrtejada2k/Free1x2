<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.SalirFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock
                Text="¿Salir del programa?"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Confirma si deseas cerrar Free1X2."
                Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <!-- Tarjeta de confirmación -->
        <Border
            Grid.Row="1"
            Style="{StaticResource AppCardStyle}"
            VerticalAlignment="Top"
            MaxWidth="460"
            HorizontalAlignment="Left">
            <StackPanel Spacing="20">

                <TextBlock
                    Text="Se cerrará la aplicación y se perderán los cambios no guardados."
                    TextWrapping="Wrap"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Foreground="{ThemeResource AppTextBrush}" />

                <!-- Checkbox legacy: chbNoMostrar -->
                <ToggleSwitch
                    Header="No mostrar este mensaje de nuevo"
                    OnContent="Activado"
                    OffContent="Desactivado"
                    IsOn="{x:Bind ViewModel.NoMostrarDeNuevo, Mode=TwoWay}"
                    AutomationProperties.Name="No mostrar de nuevo la advertencia de salida" />

                <!-- Acciones: Sí / Cancelar -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="12"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
                    <Button
                        Content="Cancelar"
                        Click="OnCancelarClick"
                        AutomationProperties.Name="Cancelar y no salir" />
                    <Button
                        Content="Sí, salir"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="OnConfirmarClick"
                        AutomationProperties.Name="Confirmar y salir del programa" />
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
