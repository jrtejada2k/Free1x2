<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.DiFiltrosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <ScrollViewer>
        <Grid Padding="12,8" RowSpacing="6" ColumnSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Encabezado -->
            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                <TextBlock Text="Diferencias entre filtros"
                           Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Toma el primer filtro como base y, para cada filtro siguiente, conserva solo las columnas que difieren según la distancia (difs 0-3) y el mínimo configurados por fila."
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Tarjeta: lista de filtros (DataGrid legacy) -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource AppCardStyle}">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Filtros"
                               Style="{StaticResource SectionHeaderTextBlockStyle}" />

                    <!-- DataGrid legacy -> ListView -->
                    <ListView Grid.Row="1"
                              MinHeight="240"
                              ItemsSource="{x:Bind ViewModel.Filtros, Mode=OneWay}"
                              SelectionMode="None"
                              Background="{ThemeResource AppSurfaceAltBrush}"
                              BorderBrush="{ThemeResource AppBorderBrush}"
                              BorderThickness="1">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="N"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" Text="Filtro"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="2" Text="Activo"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="3" Text="Cols."
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="4" Text="Difs"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="5" Text="Mín."
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="6" Text="Adm."
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="7" Text="14"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                    <TextBlock Grid.Column="8" Text="13"
                                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:DiFiltroFilaViewModel">
                                <Grid Padding="0,4" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="36" />
                                    </Grid.ColumnDefinitions>
                                    <!-- N -->
                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind NumeroTexto, Mode=OneWay}"
                                               VerticalAlignment="Center" />
                                    <!-- F -->
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind Nombre, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />
                                    <!-- A -->
                                    <CheckBox Grid.Column="2"
                                              IsChecked="{x:Bind Activo, Mode=TwoWay}"
                                              VerticalAlignment="Center" />
                                    <!-- C -->
                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind ColumnasTexto, Mode=OneWay}"
                                               HorizontalTextAlignment="Right"
                                               VerticalAlignment="Center" />
                                    <!-- D (difs, máscara "1111") -->
                                    <TextBox Grid.Column="4"
                                             MaxLength="4"
                                             Text="{x:Bind Difs, Mode=TwoWay}"
                                             VerticalAlignment="Center"
                                             AutomationProperties.Name="Máscara de diferencias (1111)" />
                                    <!-- M (min) -->
                                    <NumberBox Grid.Column="5"
                                               Minimum="1"
                                               Maximum="3305"
                                               Value="{x:Bind Minimo, Mode=TwoWay}"
                                               VerticalAlignment="Center"
                                               AutomationProperties.Name="Mínimo de columnas admitidas" />
                                    <!-- R (adm.) -->
                                    <TextBlock Grid.Column="6"
                                               Text="{x:Bind AdmitidasTexto, Mode=OneWay}"
                                               HorizontalTextAlignment="Right"
                                               VerticalAlignment="Center" />
                                    <!-- 14 -->
                                    <TextBlock Grid.Column="7"
                                               Text="{x:Bind Acierta14Texto, Mode=OneWay}"
                                               HorizontalTextAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <!-- 13 -->
                                    <TextBlock Grid.Column="8"
                                               Text="{x:Bind Aciertos13Texto, Mode=OneWay}"
                                               HorizontalTextAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Columna derecha: réplica fiel del layout legacy (712x464):
                 columna vertical de botones (orden original) + grupo "Análisis resultados". -->
            <Grid Grid.Row="1" Grid.Column="1" RowSpacing="8" Width="200">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Columna vertical de botones (orden legacy):
                     Cargar Filtro, Activa/Desactiva, Salvar Lista, Cargar Lista,
                     Iniciar Proceso, Tiempo, Cancelar, Grabar, Fichero. -->
                <StackPanel Grid.Row="0" Spacing="6">
                    <!-- btnCargarFiltro -->
                    <Button Content="Cargar Filtro"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{x:Bind ViewModel.CargarFiltroCommand}" />
                    <!-- ckMD: Activa / Desactiva -->
                    <CheckBox Content="Activa / Desactiva"
                              HorizontalAlignment="Stretch"
                              IsChecked="{x:Bind ViewModel.ActivarTodas, Mode=TwoWay}"
                              Checked="ActivarTodas_Toggled"
                              Unchecked="ActivarTodas_Toggled" />
                    <!-- bSalvaLista -->
                    <Button Content="Salvar Lista"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{x:Bind ViewModel.SalvarListaCommand}" />
                    <!-- bCargaLista -->
                    <Button Content="Cargar Lista"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{x:Bind ViewModel.CargarListaCommand}" />
                    <!-- bIniciar (acento) -->
                    <Button Content="Iniciar Proceso"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{x:Bind ViewModel.IniciarCommand}" />
                    <!-- lTime: tiempo del proceso (solo lectura) -->
                    <TextBox Header="Tiempo"
                             IsReadOnly="True"
                             Text="{x:Bind ViewModel.Tiempo, Mode=OneWay}"
                             AutomationProperties.Name="Tiempo del proceso" />
                    <!-- bCancelar -->
                    <Button Content="Cancelar"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{x:Bind ViewModel.CancelarCommand}" />
                    <!-- bGrabar -->
                    <Button Content="Grabar"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{x:Bind ViewModel.GrabarCommand}" />
                    <!-- lFileR: archivo de salida (solo lectura) -->
                    <TextBox Header="Fichero"
                             IsReadOnly="True"
                             Text="{x:Bind ViewModel.ArchivoSalida, Mode=OneWay}"
                             AutomationProperties.Name="Fichero grabado" />
                </StackPanel>

                <!-- groupBox3 legacy: "Análisis resultados" (~200x120). -->
                <Border Grid.Row="1"
                        Width="200"
                        MinHeight="120"
                        Background="{ThemeResource AppSurfaceBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="8">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Análisis resultados"
                                   Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <!-- Fila 1: bFG (cargar) + lFGR (nombre fichero) -->
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Fichero…"
                                    Command="{x:Bind ViewModel.CargarGanadorasCommand}"
                                    AutomationProperties.Name="Cargar fichero de columnas ganadoras" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.FicheroGanadoras, Mode=OneWay}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <!-- Fila 2: tbCG (columna ganadora) -->
                        <TextBox MaxLength="14"
                                 Text="{x:Bind ViewModel.ColumnaGanadora, Mode=TwoWay}"
                                 AutomationProperties.Name="Columna ganadora (14 signos)" />

                        <!-- Fila 3: bAnalizar + lbCGR (índice) + bMasR/bMenosR (+/-) -->
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="Analizar"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    IsEnabled="{x:Bind ViewModel.PuedeAnalizar, Mode=OneWay}"
                                    Command="{x:Bind ViewModel.AnalizarCommand}" />
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind ViewModel.IndiceGanadoraTexto, Mode=OneWay}"
                                       MinWidth="28"
                                       HorizontalTextAlignment="Center"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       AutomationProperties.Name="Índice de la columna ganadora" />
                            <StackPanel Grid.Column="2" Spacing="2">
                                <Button Content="+"
                                        Padding="6,0"
                                        MinWidth="24"
                                        Command="{x:Bind ViewModel.GanadoraSiguienteCommand}"
                                        AutomationProperties.Name="Columna ganadora siguiente" />
                                <Button Content="−"
                                        Padding="6,0"
                                        MinWidth="24"
                                        Command="{x:Bind ViewModel.GanadoraAnteriorCommand}"
                                        AutomationProperties.Name="Columna ganadora anterior" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
