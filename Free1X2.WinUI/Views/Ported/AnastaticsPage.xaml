<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AnastaticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="10,7" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Encabezado (Text del form legacy) ===== -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Estadísticas 0.3.4" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Style="{StaticResource SecondaryTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"
                       Text="Analiza un fichero de columnas (combinaciones de 14 signos 1/X/2) y calcula estadísticas según el modo elegido." />
        </StackPanel>

        <!-- ===== Configuración del análisis ===== -->
        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Condiciones / modo de análisis (GroupBox "Condiciones" + RadioButtons legacy) -->
            <Border Grid.Column="0" Style="{StaticResource AppCardStyle}" Padding="10,7">
                <StackPanel Spacing="5">
                    <TextBlock Text="Condiciones"
                               Style="{StaticResource CardTitleTextBlockStyle}" />
                    <TextBlock Style="{StaticResource SecondaryTextBlockStyle}"
                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                               Text="Modo de análisis a aplicar sobre las columnas." />
                    <ComboBox HorizontalAlignment="Stretch"
                              Header="Modo de análisis"
                              ItemsSource="{x:Bind ViewModel.Modos}"
                              SelectedIndex="{x:Bind ViewModel.ModoSeleccionado, Mode=TwoWay}"
                              AutomationProperties.Name="Modo de análisis estadístico" />
                </StackPanel>
            </Border>

            <!-- Origen de datos (botón "Selección origen" + labels lFileIn / lColOrg legacy) -->
            <Border Grid.Column="1" Style="{StaticResource AppCardStyle}" Padding="10,7">
                <StackPanel Spacing="5">
                    <TextBlock Text="Origen de datos"
                               Style="{StaticResource CardTitleTextBlockStyle}" />

                    <Button Content="Selección origen"
                            Command="{x:Bind ViewModel.SeleccionarOrigenCommand}"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Seleccionar fichero de columnas origen" />

                    <Grid ColumnSpacing="12" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Fichero:"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind ViewModel.FicheroOrigen, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource AppTextBrush}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Columnas:"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{x:Bind ViewModel.ColumnasTexto, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource AppTextBrush}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== Acciones (botones Calcular / Mostrar resultados legacy) ===== -->
        <Border Grid.Row="2" Style="{StaticResource AppCardStyle}" Padding="10,7"
                VerticalAlignment="Top">
            <StackPanel Spacing="5">
                <TextBlock Text="Acciones"
                           Style="{StaticResource CardTitleTextBlockStyle}" />
                <TextBlock Style="{StaticResource SecondaryTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                           Text="Selecciona un origen para calcular. Tras calcular, podrás mostrar los resultados." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Calcular"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.OrigenSeleccionado, Mode=OneWay}"
                            Command="{x:Bind ViewModel.CalcularCommand}"
                            AutomationProperties.Name="Calcular estadísticas" />
                    <Button Content="Mostrar resultados"
                            IsEnabled="{x:Bind ViewModel.ResultadosListos, Mode=OneWay}"
                            Command="{x:Bind ViewModel.MostrarResultadosCommand}"
                            AutomationProperties.Name="Mostrar resultados del cálculo" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
