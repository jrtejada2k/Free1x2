<Page
    x:Class="Free1X2.WinUI.Views.Ported.VerBoletosEnEditorFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock
                Text="Ver Boletos En Editor de Texto"
                Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock
                Text="Columnas de apuesta formateadas en boletos verticales."
                Style="{StaticResource SecondaryTextBlockStyle}" />
        </StackPanel>

        <!-- Tarjeta con el editor de texto de boletos -->
        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="Boletos"
                    Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <!-- Equivale a txtBoletos: multiline, ReadOnly, fuente monoespaciada -->
                <TextBox
                    Grid.Row="1"
                    Text="{x:Bind ViewModel.BoletosTexto, Mode=OneWay}"
                    IsReadOnly="True"
                    AcceptsReturn="True"
                    TextWrapping="NoWrap"
                    FontFamily="Consolas"
                    FontSize="13"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <!-- Acciones -->
        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Spacing="12">
            <Button
                Content="Imprimir"
                Style="{StaticResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.ImprimirCommand}" />
        </StackPanel>
    </Grid>
</Page>
