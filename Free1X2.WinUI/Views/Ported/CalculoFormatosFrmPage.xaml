<Page
    x:Class="Free1X2.WinUI.Views.Ported.CalculoFormatosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer Padding="10,7">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left" Spacing="8">

            <!-- Título real del form legacy: "Saca Formatos (Indeciso)" -->
            <TextBlock
                Style="{StaticResource PageTitleTextBlockStyle}"
                Text="Saca Formatos (Indeciso)" />

            <TextBlock
                Style="{StaticResource SecondaryTextBlockStyle}"
                Text="Extrae los formatos (pares, tríos, cuartetos y quintetos) y los contactos de una columna de 14 signos y genera un informe de texto." />

            <!-- Sección: Fichero de salida -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Style="{StaticResource SectionHeaderTextBlockStyle}"
                        Text="Fichero de salida" />

                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Button
                            Content="Seleccionar fichero…"
                            Command="{x:Bind ViewModel.SeleccionarFicheroSalidaCommand}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            Text="{x:Bind ViewModel.FicheroSalidaTexto, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sección: Columna de entrada -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Style="{StaticResource SectionHeaderTextBlockStyle}"
                        Text="Columna" />

                    <TextBox
                        Header="Columna (14 signos: 1 / X / 2)"
                        MaxLength="14"
                        CharacterCasing="Upper"
                        PlaceholderText="Ej. 1X21X2111XX221"
                        Text="{x:Bind ViewModel.Columna, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Button
                        Style="{StaticResource AccentButtonStyle}"
                        Content="Sacar Formato"
                        Command="{x:Bind ViewModel.SacarFormatoCommand}" />
                </StackPanel>
            </Border>

            <!-- Sección: Informe (resultado) -->
            <Border Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="5">
                    <TextBlock
                        Style="{StaticResource SectionHeaderTextBlockStyle}"
                        Text="Informe" />

                    <TextBox
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        MinHeight="160"
                        PlaceholderText="El informe generado aparecerá aquí."
                        Text="{x:Bind ViewModel.Informe, Mode=OneWay}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
