<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.DibFormPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="10,7" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== Encabezado (Text del form legacy = "dibujos") ===== -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="Dibujos" Style="{StaticResource PageTitleTextBlockStyle}" />
            <TextBlock Style="{StaticResource SecondaryTextBlockStyle}"
                       Foreground="{ThemeResource AppTextSecondaryBrush}"
                       Text="Distribución de la estadística sobre las columnas analizadas: tabla 15x15 con totales por fila, por columna y por diagonal. Elige ver porcentajes o número de columnas." />
        </StackPanel>

        <!-- ===== Opciones de visualización (GroupBox "mostrar" + RadioButtons legacy) ===== -->
        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}" Padding="10,7">
            <StackPanel Spacing="5">
                <TextBlock Text="Mostrar"
                           Style="{StaticResource CardTitleTextBlockStyle}" />

                <!-- rbPercent (porcentajes, Checked por defecto) / rbCols (columnas):
                     ToggleSwitch Off = porcentajes ; On = columnas. -->
                <ToggleSwitch Header="Modo de visualización"
                              OffContent="Porcentajes"
                              OnContent="Columnas"
                              IsOn="{x:Bind ViewModel.MostrarColumnas, Mode=TwoWay}"
                              AutomationProperties.Name="Alternar entre porcentajes y número de columnas" />

                <!-- lncol.Text = numcol (total de columnas analizadas) -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Columnas analizadas:"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.NumColTexto, Mode=OneWay}"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource AppTextBrush}"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ===== Tabla de distribución (matriz de labels lt####/lx##/ld##/lv## legacy) ===== -->
        <Border Grid.Row="2" Style="{StaticResource AppCardStyle}" Padding="10,7">
            <Grid RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Distribución"
                           Style="{StaticResource CardTitleTextBlockStyle}" />

                <!-- Cada fila legacy: cabecera de signo + celdas de la matriz (Celdas) +
                     total de fila (lx##). Sólo se bindean propiedades string (anti-crash). -->
                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.Filas, Mode=OneWay}"
                          SelectionMode="None"
                          AutomationProperties.Name="Tabla de distribución de la estadística">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:DibFila">
                            <Grid ColumnSpacing="8" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind Cabecera}"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />

                                <TextBlock Grid.Column="1"
                                           Text="{x:Bind Celdas}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{ThemeResource AppTextBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />

                                <TextBlock Grid.Column="2"
                                           Text="{x:Bind TotalFila}"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource AppAccentBrush}"
                                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
