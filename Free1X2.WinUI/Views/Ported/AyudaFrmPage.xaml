<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.Ported.AyudaFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{ThemeResource AppBackgroundBrush}">
        <Grid Padding="12,8" RowSpacing="6" MaxWidth="640" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Encabezado: título real del form ("Recursos de ayuda" / Text="Ayuda") -->
            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock Text="Recursos de ayuda"
                           Style="{StaticResource PageTitleTextBlockStyle}" />
                <TextBlock Text="Documentación, comunidad y enlaces de soporte de Free1X2"
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           Foreground="{ThemeResource AppTextSecondaryBrush}" />
            </StackPanel>

            <!-- Tarjeta: documentación (Manual, Artículos, FAQ, Recursos) -->
            <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Documentación"
                               Style="{StaticResource CardTitleTextBlockStyle}"
                               Margin="0,0,0,4" />

                    <HyperlinkButton Content="Manual"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="ManualLink_Click"
                                     AutomationProperties.Name="Abrir el manual de usuario" />

                    <HyperlinkButton Content="Artículos"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="ArticulosLink_Click"
                                     AutomationProperties.Name="Ver los artículos de ayuda" />

                    <HyperlinkButton Content="FAQ"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="FaqLink_Click"
                                     AutomationProperties.Name="Abrir las preguntas frecuentes (FAQ)" />

                    <HyperlinkButton Content="Recursos"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="RecursosLink_Click"
                                     AutomationProperties.Name="Ver recursos adicionales" />
                </StackPanel>
            </Border>

            <!-- Tarjeta: comunidad (Foro, Notificaciones, Facebook) -->
            <Border Grid.Row="2" Style="{StaticResource AppCardStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="Comunidad"
                               Style="{StaticResource CardTitleTextBlockStyle}"
                               Margin="0,0,0,4" />

                    <HyperlinkButton Content="Foro de Free1X2"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="ForoLink_Click"
                                     AutomationProperties.Name="Abrir el foro de Free1X2" />

                    <HyperlinkButton Content="Notificaciones"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="NotificacionesLink_Click"
                                     AutomationProperties.Name="Ver notificaciones" />

                    <HyperlinkButton Content="Free1X2 en Facebook"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Left"
                                     Click="FacebookLink_Click"
                                     AutomationProperties.Name="Abrir la página de Free1X2 en Facebook" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
