<Page
    x:Class="Free1X2.WinUI.Views.Ported.DialogoGrabarTramosFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Encabezado: título real del form legacy ("Grabar Tramos") -->
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource PageTitleTextBlockStyle}"
            Text="Grabar Tramos" />

        <ScrollViewer Grid.Row="1" Margin="0,16,0,0">
            <StackPanel Spacing="16" MaxWidth="520" HorizontalAlignment="Left">

                <!-- Rango de columnas -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Style="{StaticResource SectionHeaderTextBlockStyle}"
                            Text="Rango de columnas" />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <NumberBox
                                Grid.Column="0"
                                Header="Columna inicial"
                                Minimum="0"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.ColumnaInicial, Mode=TwoWay}" />

                            <NumberBox
                                Grid.Column="1"
                                Header="Columna final"
                                Minimum="0"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.ColumnaFinal, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Patrón de grabado: "grabar N columnas de cada P columnas" -->
                <Border Style="{StaticResource AppCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock
                            Style="{StaticResource SectionHeaderTextBlockStyle}"
                            Text="Grabar" />

                        <TextBlock
                            Style="{StaticResource SecondaryTextBlockStyle}"
                            Text="Grabar N columnas de cada P columnas." />

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <NumberBox
                                Grid.Column="0"
                                Header="Columnas a grabar (N)"
                                Minimum="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.NumColsPorPaso, Mode=TwoWay}" />

                            <NumberBox
                                Grid.Column="1"
                                Header="De cada (P) columnas"
                                Minimum="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.Paso, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Botón Aceptar (legacy: btGrabar) -->
                <Button
                    HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Aceptar"
                    Command="{x:Bind ViewModel.GrabarCommand}" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
