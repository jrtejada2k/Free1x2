<Page
    x:Class="Free1X2.WinUI.Views.Ported.ControlTolFrmPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Free1X2.WinUI.Views.Ported"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="24" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource PageTitleTextBlockStyle}"
            Text="Control Tolerancias" />

        <!-- Fallos permitidos -->
        <Border Grid.Row="1" Style="{StaticResource AppCardStyle}">
            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Text="Fallos Controles" />
                <TextBlock
                    Style="{StaticResource SecondaryTextBlockStyle}"
                    Text="Número de fallos permitidos en los controles." />
                <TextBox
                    MaxWidth="200"
                    HorizontalAlignment="Left"
                    PlaceholderText="Fallos permitidos"
                    Text="{x:Bind ViewModel.FallosPermitidos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Border>

        <!-- Tabla de tolerancias -->
        <Border Grid.Row="2" Style="{StaticResource AppCardStyle}">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Style="{StaticResource SectionHeaderTextBlockStyle}"
                    Text="Tolerancias" />

                <!-- Cabeceras de columnas -->
                <Grid Grid.Row="1" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Text="Tolerancia" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource CardTitleTextBlockStyle}"
                        Text="Aciertos" />
                </Grid>

                <ListView
                    Grid.Row="2"
                    ItemsSource="{x:Bind ViewModel.Tolerancias, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ToleranciaItem">
                            <Grid ColumnSpacing="12" Padding="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Grid.Column="0"
                                    PlaceholderText="Tolerancia"
                                    Text="{x:Bind LetrasTol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox
                                    Grid.Column="1"
                                    PlaceholderText="Aciertos"
                                    Text="{x:Bind Aciertos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Botones -->
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Spacing="12">
            <Button
                Content="Cancelar"
                Command="{x:Bind ViewModel.CancelarCommand}" />
            <Button
                Style="{StaticResource AccentButtonStyle}"
                Content="Ok"
                Command="{x:Bind ViewModel.GuardarCommand}" />
        </StackPanel>
    </Grid>
</Page>
