<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Free1X2.WinUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="32" Spacing="20" MaxWidth="640" HorizontalAlignment="Left">
        <TextBlock Text="Ajustes" Style="{StaticResource TitleTextBlockStyle}" />

        <StackPanel Spacing="8">
            <TextBlock Text="Tema" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <RadioButtons x:Name="TemaRadios" SelectionChanged="TemaRadios_SelectionChanged">
                <x:String>Claro</x:String>
                <x:String>Oscuro</x:String>
                <x:String>Sistema</x:String>
            </RadioButtons>
        </StackPanel>

        <Border Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                CornerRadius="{StaticResource AppCardCornerRadius}" Padding="20">
            <StackPanel Spacing="4">
                <TextBlock Text="Free1X2 — WinUI 3" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Migración en curso desde WinForms. Lógica de dominio reutilizada."
                           Foreground="{ThemeResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
