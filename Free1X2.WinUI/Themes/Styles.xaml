<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:controls="using:Free1X2.WinUI.Controls">

    <!-- ============================================================
         Estilos reutilizables del sistema de diseño Free1X2.
         Sólo usa ThemeResource/StaticResource de Tokens.xaml.
         ============================================================ -->

    <!-- ===== Tipografía / encabezados ===== -->
    <!-- Densidad compacta: títulos de página ~21px, cabeceras ~15px, descripciones ~12px,
         alineado con la densidad de MainPage (texto/controles a 12px). Sólo tamaño, sin tocar color. -->
    <!-- Título de página: variante óptica Display (pensada para tamaños grandes),
         peso SemiBold para jerarquía, y un tracking positivo sutil (+30) que da
         un toque elegante sin riesgo de recorte. Sólo familia/peso/espaciado. -->
    <Style x:Key="PageTitleTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource TitleLargeTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyDisplay}" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="30" />
        <Setter Property="LineHeight" Value="26" />
    </Style>

    <!-- Cabecera de sección: variante Display + SemiBold. -->
    <Style x:Key="SectionHeaderTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource SubtitleTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyDisplay}" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <!-- Título de tarjeta: variante Text + SemiBold. -->
    <Style x:Key="CardTitleTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyText}" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="18" />
    </Style>

    <!-- Texto secundario/descripción: variante Small, peso Regular, color apagado. -->
    <Style x:Key="SecondaryTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilySmall}" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="16" />
    </Style>

    <!-- Título de tarjeta con acento ÍNDIGO: misma métrica que CardTitle pero el
         color de acento da identidad a la sección (pulido PRO). Sólo color. -->
    <Style x:Key="AccentCardTitleTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource CardTitleTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource AppAccentBrush}" />
    </Style>

    <!-- Título de tarjeta con acento TEAL: identidad secundaria para distinguir
         secciones contiguas (p. ej. Filtro vs. Filtro Parcial). Sólo color. -->
    <Style x:Key="SecondaryCardTitleTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource CardTitleTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource AppSecondaryBrush}" />
    </Style>

    <!-- "Chip" de icono: fondo redondeado y tintado tras un glifo, para dar
         profundidad/color a los iconos de las secciones de filtro (pulido PRO).
         El color de tinte se fija por instancia (Background). Sólo visual. -->
    <Style x:Key="IconChipBorderStyle" TargetType="Border">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="CornerRadius" Value="7" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- ============================================================
         Compactación de los estilos de tipografía integrados (WinUI) que
         algunas páginas portadas usan directamente como título/cabecera.
         Sólo se reduce el TAMAÑO (FontSize/LineHeight); se conservan peso,
         color y comportamiento heredados del estilo base del framework.
         Sin esto, esas páginas mantendrían el título grande (~28/40px).
         ============================================================ -->
    <Style x:Key="TitleTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyDisplay}" />
        <Setter Property="FontSize" Value="21" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="26" />
    </Style>

    <Style x:Key="SubtitleTextBlockStyle" TargetType="TextBlock"
           BasedOn="{StaticResource BaseTextBlockStyle}">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamilyDisplay}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <!-- ============================================================
         Densidad compacta de controles de entrada (implícitos, app-wide).
         Sólo tamaño/fuente/relleno: altura ~30px y texto 12px, igual que
         los controles inline de MainPage. No cambia color ni comportamiento.
         Los valores inline de cada página (Height/FontSize) tienen prioridad.
         ============================================================ -->
    <Style TargetType="TextBox" BasedOn="{StaticResource DefaultTextBoxStyle}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,4,0,4" />
    </Style>

    <!-- NumberBox: sin BasedOn. WinUI no expone de forma fiable la clave
         "DefaultNumberBoxStyle" en esta versión, y referenciarla rompe la carga
         de cualquier página con NumberBox ("Cannot find a Resource ... DefaultNumberBoxStyle").
         Un Style implícito sin BasedOn aplica la plantilla integrada del framework
         y sólo sobrescribe el tamaño/fuente para mantener la densidad compacta. -->
    <Style TargetType="muxc:NumberBox">
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- ===== Card (Border con esquinas redondeadas + borde sutil + elevación) ===== -->
    <!-- Padding compacto (densidad cercana al MainForm original). -->
    <!-- Profundidad: ThemeShadow compartido + Translation Z=16 → sombra Fluent
         suave que despega la tarjeta del fondo de página. El borde fino de 1px
         (AppBorderBrush) se mantiene para definir el contorno; la sombra aporta
         la separación visual. Sólo visual: no cambia tamaño/disposición. -->
    <Style x:Key="AppCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCardCornerRadius}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Shadow" Value="{StaticResource AppCardShadow}" />
        <!-- Translation Z=16 → la tarjeta proyecta la sombra Fluent. Se aplica
             vía propiedad adjunta porque UIElement.Translation no es válida en
             un Setter de Style (limitación del compilador XAML de WinUI 3). -->
        <Setter Property="controls:CardElevation.Depth" Value="16" />
    </Style>

    <!-- ===== Toggle de signo 1 / X / 2 del boleto ===== -->
    <Style x:Key="SignoToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0,3" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ============================================================
         Botón de filtro — 4 estados (Activo / Error / Neutro / Inactivo).
         Equivale a SetBotonEstado(...) del MainForm WinForms.
         ============================================================ -->

    <!-- Base común de los botones de filtro -->
    <Style x:Key="FiltroButtonBaseStyle" TargetType="Button">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="CornerRadius" Value="{StaticResource AppCornerRadius}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <!-- Inactivo: superficie neutra (estado por defecto) -->
    <Style x:Key="FiltroButtonInactivoStyle" TargetType="Button"
           BasedOn="{StaticResource FiltroButtonBaseStyle}">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
    </Style>

    <!-- Neutro: filtro presente pero sin evaluar (ámbar suave) -->
    <Style x:Key="FiltroButtonNeutroStyle" TargetType="Button"
           BasedOn="{StaticResource FiltroButtonBaseStyle}">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{ThemeResource AppWarningBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppWarningBrush}" />
    </Style>

    <!-- Activo: filtro aplicado correctamente (verde) -->
    <Style x:Key="FiltroButtonActivoStyle" TargetType="Button"
           BasedOn="{StaticResource FiltroButtonBaseStyle}">
        <Setter Property="Background" Value="{ThemeResource AppSuccessBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppSuccessBrush}" />
    </Style>

    <!-- Error: filtro con datos pero inválido (rojo) -->
    <Style x:Key="FiltroButtonErrorStyle" TargetType="Button"
           BasedOn="{StaticResource FiltroButtonBaseStyle}">
        <Setter Property="Background" Value="{ThemeResource AppErrorBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppErrorBrush}" />
    </Style>

</ResourceDictionary>
