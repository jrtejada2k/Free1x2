<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Sistema de diseño Free1X2 — paleta Slate / Indigo
         Mapeo de los tokens de ModernTheme.cs a recursos WinUI 3.
         ============================================================ -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- ===== LIGHT (paleta cálida, inspirada en el Free1X2 original) ===== -->
        <ResourceDictionary x:Key="Light">
            <!-- Acento naranja/terracota (barra de herramientas del original) -->
            <Color x:Key="SystemAccentColor">#C2541E</Color>
            <Color x:Key="SystemAccentColorLight1">#D2691E</Color>
            <Color x:Key="SystemAccentColorLight2">#E0884A</Color>
            <Color x:Key="SystemAccentColorDark1">#A8460F</Color>
            <Color x:Key="SystemAccentColorDark2">#8A3A0C</Color>

            <Color x:Key="AppBackground">#FBF1E7</Color><!-- crema cálida -->
            <Color x:Key="AppSurface">#FFFFFF</Color>
            <Color x:Key="AppSurfaceAlt">#F8E2D0</Color><!-- salmón tenue (paneles/cabeceras) -->
            <Color x:Key="AppBorder">#E3C6AE</Color>
            <Color x:Key="AppText">#2A211C</Color>
            <Color x:Key="AppTextSecondary">#6E574A</Color>
            <Color x:Key="AppSuccess">#2E7D32</Color><!-- verde (condición/signo activo) -->
            <Color x:Key="AppWarning">#B45309</Color>
            <Color x:Key="AppOnSuccess">#FFFFFF</Color>
            <Color x:Key="AppError">#C0392B</Color>

            <!-- Signos 1/X/2 marcados en verde, como el boleto del original -->
            <SolidColorBrush x:Key="ToggleButtonBackgroundChecked"            Color="#2E7D32" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#357A38" />
            <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed"     Color="#27692B" />
            <SolidColorBrush x:Key="ToggleButtonForegroundChecked"            Color="#FFFFFF" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed"     Color="#FFFFFF" />

            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="{StaticResource AppBackground}" />
            <SolidColorBrush x:Key="AppSurfaceBrush"        Color="{StaticResource AppSurface}" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush"     Color="{StaticResource AppSurfaceAlt}" />
            <SolidColorBrush x:Key="AppBorderBrush"         Color="{StaticResource AppBorder}" />
            <SolidColorBrush x:Key="AppTextBrush"           Color="{StaticResource AppText}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush"  Color="{StaticResource AppTextSecondary}" />
            <SolidColorBrush x:Key="AppSuccessBrush"        Color="{StaticResource AppSuccess}" />
            <SolidColorBrush x:Key="AppWarningBrush"        Color="{StaticResource AppWarning}" />
            <SolidColorBrush x:Key="AppErrorBrush"          Color="{StaticResource AppError}" />
            <SolidColorBrush x:Key="AppAccentBrush"         Color="{StaticResource SystemAccentColor}" />
        </ResourceDictionary>

        <!-- ===== DARK ===== -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="SystemAccentColor">#818CF8</Color>
            <Color x:Key="SystemAccentColorLight1">#A5B4FC</Color>
            <Color x:Key="SystemAccentColorLight2">#C7D2FE</Color>
            <Color x:Key="SystemAccentColorDark1">#6366F1</Color>
            <Color x:Key="SystemAccentColorDark2">#4F46E5</Color>

            <Color x:Key="AppBackground">#0B1120</Color>
            <Color x:Key="AppSurface">#0F172A</Color>
            <Color x:Key="AppSurfaceAlt">#1E293B</Color>
            <Color x:Key="AppBorder">#334155</Color>
            <Color x:Key="AppText">#F1F5F9</Color>
            <Color x:Key="AppTextSecondary">#94A3B8</Color>
            <Color x:Key="AppSuccess">#16A34A</Color><!-- green-600 (dark): mejor contraste con texto blanco -->
            <Color x:Key="AppWarning">#F59E0B</Color>
            <Color x:Key="AppOnSuccess">#FFFFFF</Color>
            <Color x:Key="AppError">#EF4444</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="{StaticResource AppBackground}" />
            <SolidColorBrush x:Key="AppSurfaceBrush"        Color="{StaticResource AppSurface}" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush"     Color="{StaticResource AppSurfaceAlt}" />
            <SolidColorBrush x:Key="AppBorderBrush"         Color="{StaticResource AppBorder}" />
            <SolidColorBrush x:Key="AppTextBrush"           Color="{StaticResource AppText}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush"  Color="{StaticResource AppTextSecondary}" />
            <SolidColorBrush x:Key="AppSuccessBrush"        Color="{StaticResource AppSuccess}" />
            <SolidColorBrush x:Key="AppWarningBrush"        Color="{StaticResource AppWarning}" />
            <SolidColorBrush x:Key="AppErrorBrush"          Color="{StaticResource AppError}" />
            <SolidColorBrush x:Key="AppAccentBrush"         Color="{StaticResource SystemAccentColor}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Tokens no dependientes del tema ===== -->
    <x:Double x:Key="AppCornerRadiusValue">8</x:Double>
    <CornerRadius x:Key="AppCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="AppCardCornerRadius">12</CornerRadius>

    <!-- Densidad compacta (alineada con MainPage: page 12,8 / card 10,7 / spacing 5-6). -->
    <Thickness x:Key="AppSpacingSmall">6</Thickness>
    <Thickness x:Key="AppSpacingMedium">8</Thickness>
    <Thickness x:Key="AppSpacingLarge">10</Thickness>
    <Thickness x:Key="AppPagePadding">12,8</Thickness>

</ResourceDictionary>
