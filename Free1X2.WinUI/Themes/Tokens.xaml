<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Sistema de diseño Free1X2 — paleta Slate / Indigo
         Mapeo de los tokens de ModernTheme.cs a recursos WinUI 3.
         ============================================================ -->
    <ResourceDictionary.ThemeDictionaries>

        <!-- ===== LIGHT ===== -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="SystemAccentColor">#4F46E5</Color>
            <Color x:Key="SystemAccentColorLight1">#6366F1</Color>
            <Color x:Key="SystemAccentColorLight2">#818CF8</Color>
            <Color x:Key="SystemAccentColorDark1">#4338CA</Color>
            <Color x:Key="SystemAccentColorDark2">#3730A3</Color>

            <Color x:Key="AppBackground">#F5F7FA</Color>
            <Color x:Key="AppSurface">#FFFFFF</Color>
            <Color x:Key="AppSurfaceAlt">#F1F5F9</Color>
            <Color x:Key="AppBorder">#CBD5E1</Color>
            <Color x:Key="AppText">#0F172A</Color>
            <Color x:Key="AppTextSecondary">#334155</Color>
            <Color x:Key="AppSuccess">#15803D</Color><!-- green-700: texto blanco AA (4.5:1) -->
            <Color x:Key="AppWarning">#B45309</Color><!-- amber-700: texto sobre SurfaceAlt AA -->
            <Color x:Key="AppOnSuccess">#FFFFFF</Color>
            <Color x:Key="AppError">#DC2626</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="{StaticResource AppBackground}" />
            <SolidColorBrush x:Key="AppSurfaceBrush"        Color="{StaticResource AppSurface}" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush"     Color="{StaticResource AppSurfaceAlt}" />
            <SolidColorBrush x:Key="AppBorderBrush"         Color="{StaticResource AppBorder}" />
            <SolidColorBrush x:Key="AppTextBrush"           Color="{StaticResource AppText}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush"  Color="{StaticResource AppTextSecondary}" />
            <SolidColorBrush x:Key="AppSuccessBrush"        Color="{StaticResource AppSuccess}" />
            <SolidColorBrush x:Key="AppWarningBrush"        Color="{StaticResource AppWarning}" />
            <SolidColorBrush x:Key="AppErrorBrush"          Color="{StaticResource AppError}" />
            <SolidColorBrush x:Key="AppAccentBrush"         Color="{StaticResource SystemAccentColor}" />
        </ResourceDictionary>

        <!-- ===== DARK ===== -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="SystemAccentColor">#818CF8</Color>
            <Color x:Key="SystemAccentColorLight1">#A5B4FC</Color>
            <Color x:Key="SystemAccentColorLight2">#C7D2FE</Color>
            <Color x:Key="SystemAccentColorDark1">#6366F1</Color>
            <Color x:Key="SystemAccentColorDark2">#4F46E5</Color>

            <Color x:Key="AppBackground">#0B1120</Color>
            <Color x:Key="AppSurface">#0F172A</Color>
            <Color x:Key="AppSurfaceAlt">#1E293B</Color>
            <Color x:Key="AppBorder">#334155</Color>
            <Color x:Key="AppText">#F1F5F9</Color>
            <Color x:Key="AppTextSecondary">#94A3B8</Color>
            <Color x:Key="AppSuccess">#16A34A</Color><!-- green-600 (dark): mejor contraste con texto blanco -->
            <Color x:Key="AppWarning">#F59E0B</Color>
            <Color x:Key="AppOnSuccess">#FFFFFF</Color>
            <Color x:Key="AppError">#EF4444</Color>

            <SolidColorBrush x:Key="AppBackgroundBrush"     Color="{StaticResource AppBackground}" />
            <SolidColorBrush x:Key="AppSurfaceBrush"        Color="{StaticResource AppSurface}" />
            <SolidColorBrush x:Key="AppSurfaceAltBrush"     Color="{StaticResource AppSurfaceAlt}" />
            <SolidColorBrush x:Key="AppBorderBrush"         Color="{StaticResource AppBorder}" />
            <SolidColorBrush x:Key="AppTextBrush"           Color="{StaticResource AppText}" />
            <SolidColorBrush x:Key="AppTextSecondaryBrush"  Color="{StaticResource AppTextSecondary}" />
            <SolidColorBrush x:Key="AppSuccessBrush"        Color="{StaticResource AppSuccess}" />
            <SolidColorBrush x:Key="AppWarningBrush"        Color="{StaticResource AppWarning}" />
            <SolidColorBrush x:Key="AppErrorBrush"          Color="{StaticResource AppError}" />
            <SolidColorBrush x:Key="AppAccentBrush"         Color="{StaticResource SystemAccentColor}" />
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Tokens no dependientes del tema ===== -->
    <x:Double x:Key="AppCornerRadiusValue">8</x:Double>
    <CornerRadius x:Key="AppCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="AppCardCornerRadius">12</CornerRadius>

    <Thickness x:Key="AppSpacingSmall">8</Thickness>
    <Thickness x:Key="AppSpacingMedium">12</Thickness>
    <Thickness x:Key="AppSpacingLarge">16</Thickness>
    <Thickness x:Key="AppPagePadding">24</Thickness>

</ResourceDictionary>
