<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Free1X2.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <!-- Sin barra de título custom: se usa la barra de Windows estándar
         (minimizar / maximizar / cerrar) como el MainForm WinForms original. -->
    <Grid Background="{ThemeResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Barra de menús (organización del programa original) -->
        <muxc:MenuBar x:Name="BarraMenu" Grid.Row="0" />

        <!-- Barra de herramientas (réplica de los 6 ToolStrips del MainForm) -->
        <Border x:Name="BarraHerramientas" Grid.Row="1"
                Background="{ThemeResource AppSurfaceAltBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,1,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Auto">
                <StackPanel x:Name="ToolbarPanel" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="6,2" Spacing="1" />
            </ScrollViewer>
        </Border>

        <!-- Contenido -->
        <Frame x:Name="ContentFrame" Grid.Row="2" />
    </Grid>
</Window>
